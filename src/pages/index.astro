---
import Layout from '../layouts/Layout.astro';
import CampusMap from '../components/CampusMap.astro';
import { db, Groups, Plants, eq } from 'astro:db';

const groupsData = await db.select().from(Groups);
const plantsData = await db.select().from(Plants);

const groups = groupsData.map(group => {
  const plantsInGroup = plantsData
    .filter(p => p.groupId === group.id)
    .sort((a, b) => a.scientificName.localeCompare(b.scientificName));
    
  return { ...group, plants: plantsInGroup };
});
---

<Layout>
	<main class="pb-32">
		<!-- Dynamic Top Navigation (Sticky) -->
		<nav class="sticky top-0 z-40 glass border-b-[0.5px] border-slate-200 px-5 pt-12 pb-3 transition-all duration-300" id="top-nav">
			<div class="flex justify-between items-center mb-1">
				<span class="text-[13px] font-bold text-slate-400 uppercase tracking-widest">Woody ID</span>
				<a href="/admin" class="text-emerald-700 text-sm font-semibold hover:opacity-70 transition-opacity">Admin</a>
			</div>
			<h1 class="large-title transition-all duration-300" id="nav-title">Library</h1>
		</nav>

		<!-- Library View -->
		<div id="lists-view" class="mt-6 px-4 animate-in fade-in duration-500">
			<div class="ios-inset-list shadow-sm">
				{groups.map((group, index) => (
					<button 
						class="group-widget w-full ios-row text-left"
						data-group-id={group.id}
					>
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-xl flex items-center justify-center bg-slate-100 text-slate-600">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
							</div>
							<div>
								<div class="text-[17px] font-semibold text-slate-800 leading-tight">{group.name}</div>
								<div class="text-[13px] text-slate-400 font-medium mt-0.5">{group.plants.length} Species cataloged</div>
							</div>
						</div>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" />
						</svg>
					</button>
				))}
			</div>
			
			<!-- Branding/Footer Info -->
			<div class="mt-8 px-2 text-center">
				<p class="text-[13px] text-slate-400 font-medium leading-relaxed">
					University of Georgia<br/>Woody Ornamentals Laboratory
				</p>
			</div>
		</div>

		<!-- Detail View -->
		<div id="group-detail" class="hidden fixed inset-0 z-50 bg-slate-50 overflow-y-auto no-scrollbar animate-in slide-in-from-right duration-300">
			<header class="sticky top-0 z-10 glass border-b-[0.5px] border-slate-200 px-4 py-4 flex items-center justify-between">
				<button id="close-detail" class="text-emerald-700 flex items-center gap-1 font-semibold">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					<span>Library</span>
				</button>
				<h2 id="header-detail-title" class="text-[17px] font-bold text-slate-800 truncate px-4"></h2>
				<div class="w-20"></div> <!-- Spacer -->
			</header>
			
			<div class="px-5 mt-6 mb-8">
				<h2 id="detail-title" class="large-title"></h2>
			</div>

			<div id="detail-list" class="space-y-6 px-4 pb-24">
				<!-- Plant cards injected here -->
			</div>
		</div>

		<!-- Maps View -->
		<div id="maps-view" class="hidden fixed inset-0 z-30 bg-white">
			<div class="h-full flex flex-col pt-safe">
				<div class="px-5 py-3 border-b-[0.5px] border-slate-200 glass shrink-0">
					<h2 class="text-[17px] font-bold text-center text-slate-800 uppercase tracking-widest">Campus Discovery</h2>
				</div>
				<div class="flex-grow">
					<CampusMap />
				</div>
			</div>
		</div>

		<!-- Mature iOS Tab Bar -->
		<nav class="fixed bottom-0 left-0 right-0 z-[60] glass border-t-[0.5px] border-slate-200 pb-safe">
			<div class="flex h-16 max-w-lg mx-auto">
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1.5 transition-colors text-emerald-700" 
					data-view="lists"
				>
					<div class="p-1.5 rounded-xl transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
					</div>
					<span class="text-[10px] font-bold uppercase tracking-widest">Library</span>
				</button>
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1.5 transition-colors text-slate-400" 
					data-view="maps"
				>
					<div class="p-1.5 rounded-xl transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
					</div>
					<span class="text-[10px] font-bold uppercase tracking-widest">Campus Map</span>
				</button>
			</div>
		</nav>
	</main>
</Layout>

<script define:vars={{ groups }}>
	const tabButtons = document.querySelectorAll('.tab-btn');
	const listsView = document.getElementById('lists-view');
	const mapsView = document.getElementById('maps-view');
	const groupWidgets = document.querySelectorAll('.group-widget');
	const groupDetail = document.getElementById('group-detail');
	const detailTitle = document.getElementById('detail-title');
	const headerDetailTitle = document.getElementById('header-detail-title');
	const detailList = document.getElementById('detail-list');
	const closeDetail = document.getElementById('close-detail');

	const switchTab = (view) => {
		tabButtons.forEach(btn => {
			if (btn.dataset.view === view) {
				btn.classList.add('text-emerald-700');
				btn.classList.remove('text-slate-400');
			} else {
				btn.classList.remove('text-emerald-700');
				btn.classList.add('text-slate-400');
			}
		});

		if (view === 'lists') {
			listsView.classList.remove('hidden');
			document.getElementById('top-nav').classList.remove('hidden');
			mapsView.classList.add('hidden');
		} else {
			listsView.classList.add('hidden');
			document.getElementById('top-nav').classList.add('hidden');
			groupDetail.classList.add('hidden');
			mapsView.classList.remove('hidden');
			window.dispatchEvent(new Event('resize'));
		}
	};

	tabButtons.forEach(btn => {
		btn.addEventListener('click', () => switchTab(btn.dataset.view));
	});

	groupWidgets.forEach(widget => {
		widget.addEventListener('click', () => {
			const groupId = widget.dataset.groupId;
			const group = groups.find(g => g.id === groupId);
			
			if (group) {
				detailTitle.textContent = group.name;
				headerDetailTitle.textContent = group.name;
				groupDetail.classList.remove('hidden');
				document.body.classList.add('overflow-hidden');
				
				detailList.innerHTML = group.plants.map((plant) => `
					<div class="bg-white rounded-3xl overflow-hidden border-[0.5px] border-slate-200 shadow-sm transition-all hover:shadow-md">
						${plant.imageUrl ? `
							<div class="w-full h-56 bg-slate-100 overflow-hidden relative">
								<img src="${plant.imageUrl}" class="w-full h-full object-cover" loading="lazy" />
								<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
							</div>
						` : ''}
						<div class="p-6">
							<div class="flex items-start justify-between mb-6">
								<div class="min-w-0">
									<div class="text-[22px] font-bold text-slate-900 leading-tight">${plant.scientificName}</div>
									<div class="text-[15px] font-medium text-slate-400 italic mt-0.5">${plant.commonName}</div>
								</div>
								${plant.latitude ? `
									<button 
										class="see-on-map-btn w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 active:scale-90 transition-all shrink-0"
										data-lat="${plant.latitude}"
										data-lng="${plant.longitude}"
										data-id="${plant.id}"
									>
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
									</button>
								` : ''}
							</div>

							<div class="grid grid-cols-1 gap-y-4">
								${[
									{ label: 'Leaf Arrangement', val: plant.leafArrangement },
									{ label: 'Leaf Shape', val: plant.leafShape },
									{ label: 'Leaf Margin', val: plant.leafMargin },
									{ label: 'Bark Features', val: plant.bark },
									{ label: 'Flower', val: plant.flower },
									{ label: 'Fruit', val: plant.fruit }
								].filter(f => f.val).map(f => `
									<div class="flex items-baseline gap-4">
										<div class="w-24 shrink-0 text-[11px] font-black text-slate-300 uppercase tracking-widest">${f.label}</div>
										<div class="text-[15px] text-slate-700 font-medium leading-snug">${f.val}</div>
									</div>
								`).join('')}
							</div>
						</div>
					</div>
				`).join('');
				
				groupDetail.scrollTo({ top: 0, behavior: 'instant' });

				document.querySelectorAll('.see-on-map-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						const { lat, lng, id } = btn.dataset;
						switchTab('maps');
						groupDetail.classList.add('hidden');
						document.body.classList.remove('overflow-hidden');
						if (window.focusPlant) {
							window.focusPlant(parseFloat(lat), parseFloat(lng), id);
						}
					});
				});
			}
		});
	});

	closeDetail.addEventListener('click', () => {
		groupDetail.classList.add('hidden');
		document.body.classList.remove('overflow-hidden');
	});

	// Dynamic nav effect
	window.addEventListener('scroll', () => {
		const nav = document.getElementById('top-nav');
		const title = document.getElementById('nav-title');
		if (window.scrollY > 40) {
			nav.classList.add('py-2');
			nav.classList.remove('pt-12', 'pb-3');
			title.style.fontSize = '20px';
		} else {
			nav.classList.remove('py-2');
			nav.classList.add('pt-12', 'pb-3');
			title.style.fontSize = '34px';
		}
	});
</script>
