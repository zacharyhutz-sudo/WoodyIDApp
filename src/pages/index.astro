---
import Layout from '../layouts/Layout.astro';
import CampusMap from '../components/CampusMap.astro';
import { db, Groups, Plants, eq } from 'astro:db';

const groupsData = await db.select().from(Groups);
const plantsData = await db.select().from(Plants);

const groups = groupsData.map(group => {
  const plantsInGroup = plantsData
    .filter(p => p.groupId === group.id)
    .sort((a, b) => a.scientificName.localeCompare(b.scientificName));
    
  return { ...group, plants: plantsInGroup };
});

const numberMap: Record<string, string> = {
  '01': 'One', '02': 'Two', '03': 'Three', '04': 'Four', '05': 'Five',
  '06': 'Six', '07': 'Seven', '08': 'Eight', '09': 'Nine', '10': 'Ten'
};

const getDisplayNumber = (name: string) => {
  const parts = name.split(' ');
  if (parts.length < 2) return name;
  const num = parts[1];
  return numberMap[num] || num;
};
---

<Layout>
	<main class="pb-32 pt-12">
		<!-- Header with Large Title -->
		<div id="lists-header" class="px-5 mb-6">
			<div class="flex justify-between items-end mb-1">
				<span class="text-[13px] font-semibold text-[#8E8E93] uppercase tracking-tight">University of Georgia</span>
				<a href="/admin" class="text-[#007AFF] text-sm font-medium">Admin</a>
			</div>
			<h1 class="large-title">Woody ID</h1>
		</div>

		<!-- Lists View Content -->
		<div id="lists-view" class="space-y-8 animate-in fade-in duration-500">
			<!-- Grouped List -->
			<div class="px-4">
				<div class="bg-white rounded-xl overflow-hidden border-[0.5px] border-[#C6C6C8]">
					{groups.map((group, index) => (
						<button 
							class="group-widget w-full flex items-center justify-between py-3 px-4 active:bg-[#E5E5EA] transition-colors text-left border-b-[0.5px] border-[#C6C6C8] last:border-0"
							data-group-id={group.id}
						>
							<div class="flex items-center gap-4">
								<div class={`w-7 h-7 rounded-lg flex items-center justify-center text-white text-[13px] font-bold ${['bg-[#FF9500]', 'bg-[#34C759]', 'bg-[#007AFF]', 'bg-[#5856D6]', 'bg-[#FF2D55]', 'bg-[#AF52DE]'][index % 6]}`}>
									{group.name.match(/\d+/)?.[0] || 'G'}
								</div>
								<div>
									<div class="text-[17px] font-normal text-black leading-tight">{group.name}</div>
									<div class="text-[12px] text-[#8E8E93] leading-tight mt-0.5">{group.plants.length} Species</div>
								</div>
							</div>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#C4C4C6]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
							</svg>
						</button>
					))}
				</div>
			</div>
		</div>

		<!-- Detail View (Nested Inset Grouped List) -->
		<div id="group-detail" class="hidden animate-in slide-in-from-right duration-300">
			<div class="px-5 mb-6 flex items-center gap-2">
				<button id="close-detail" class="text-[#007AFF] flex items-center -ml-2 py-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					<span class="text-[17px]">Back</span>
				</button>
			</div>
			<div class="px-5 mb-6">
				<h2 id="detail-title" class="large-title"></h2>
			</div>
			
			<div id="detail-list" class="space-y-6 px-4">
				<!-- Plant cards will be injected here -->
			</div>
		</div>

		<!-- Maps View -->
		<div id="maps-view" class="hidden absolute inset-0 z-10 bg-white">
			<div class="h-full flex flex-col pt-safe">
				<div class="px-5 py-3 border-b-[0.5px] border-[#C6C6C8] bg-white/80 backdrop-blur-xl shrink-0">
					<h2 class="text-[17px] font-semibold text-center">Discovery Map</h2>
				</div>
				<div class="flex-grow">
					<CampusMap />
				</div>
			</div>
		</div>

		<!-- iOS Bottom Tab Bar -->
		<nav class="fixed bottom-0 left-0 right-0 z-50 bg-[#F9F9F9]/80 backdrop-blur-2xl border-t-[0.5px] border-[#C6C6C8] pb-safe">
			<div class="flex h-12 md:h-16 max-w-lg mx-auto">
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1 text-[#007AFF]" 
					data-view="lists"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
					</svg>
					<span class="text-[10px] font-medium">Library</span>
				</button>
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1 text-[#8E8E93]" 
					data-view="maps"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
					</svg>
					<span class="text-[10px] font-medium">Map</span>
				</button>
			</div>
		</nav>
	</main>
</Layout>

<script define:vars={{ groups }}>
	const tabButtons = document.querySelectorAll('.tab-btn');
	const listsView = document.getElementById('lists-view');
	const mapsView = document.getElementById('maps-view');
	const listsHeader = document.getElementById('lists-header');
	const groupWidgets = document.querySelectorAll('.group-widget');
	const groupDetail = document.getElementById('group-detail');
	const detailTitle = document.getElementById('detail-title');
	const detailList = document.getElementById('detail-list');
	const closeDetail = document.getElementById('close-detail');

	const switchTab = (view) => {
		tabButtons.forEach(btn => {
			if (btn.dataset.view === view) {
				btn.classList.add('text-[#007AFF]');
				btn.classList.remove('text-[#8E8E93]');
			} else {
				btn.classList.remove('text-[#007AFF]');
				btn.classList.add('text-[#8E8E93]');
			}
		});

		if (view === 'lists') {
			listsView.classList.remove('hidden');
			listsHeader.classList.remove('hidden');
			mapsView.classList.add('hidden');
			groupDetail.classList.add('hidden');
		} else {
			listsView.classList.add('hidden');
			listsHeader.classList.add('hidden');
			groupDetail.classList.add('hidden');
			mapsView.classList.remove('hidden');
			window.dispatchEvent(new Event('resize'));
		}
	};

	tabButtons.forEach(btn => {
		btn.addEventListener('click', () => switchTab(btn.dataset.view));
	});

	groupWidgets.forEach(widget => {
		widget.addEventListener('click', () => {
			const groupId = widget.dataset.groupId;
			const group = groups.find(g => g.id === groupId);
			
			if (group) {
				detailTitle.textContent = group.name;
				listsView.classList.add('hidden');
				listsHeader.classList.add('hidden');
				groupDetail.classList.remove('hidden');
				
				detailList.innerHTML = group.plants.map((plant, index) => `
					<div class="bg-white rounded-2xl overflow-hidden border-[0.5px] border-[#C6C6C8] shadow-sm">
						${plant.imageUrl ? `
							<div class="w-full h-48 bg-stone-100 overflow-hidden">
								<img src="${plant.imageUrl}" class="w-full h-full object-cover" />
							</div>
						` : ''}
						<div class="p-4">
							<div class="flex items-start justify-between mb-4">
								<div>
									<div class="text-[20px] font-bold text-black">${plant.scientificName}</div>
									<div class="text-[15px] italic text-[#8E8E93]">${plant.commonName}</div>
								</div>
								${plant.latitude ? `
									<button 
										class="see-on-map-btn w-10 h-10 bg-[#F2F2F7] rounded-full flex items-center justify-center text-[#007AFF] active:scale-90 transition-all"
										data-lat="${plant.latitude}"
										data-lng="${plant.longitude}"
										data-id="${plant.id}"
									>
										<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
									</button>
								` : ''}
							</div>

							<div class="space-y-3">
								${[
									{ label: 'Arrangement', val: plant.leafArrangement },
									{ label: 'Shape', val: plant.leafShape },
									{ label: 'Margin', val: plant.leafMargin },
									{ label: 'Bark', val: plant.bark },
									{ label: 'Flower', val: plant.flower },
									{ label: 'Fruit', val: plant.fruit }
								].filter(f => f.val).map(f => `
									<div class="flex border-t-[0.5px] border-[#F2F2F7] pt-2">
										<div class="w-24 text-[13px] font-medium text-[#8E8E93] uppercase tracking-tight">${f.label}</div>
										<div class="flex-grow text-[15px] text-black">${f.val}</div>
									</div>
								`).join('')}
							</div>
						</div>
					</div>
				`).join('');
				
				window.scrollTo({ top: 0, behavior: 'instant' });

				document.querySelectorAll('.see-on-map-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						const { lat, lng, id } = btn.dataset;
						switchTab('maps');
						if (window.focusPlant) {
							window.focusPlant(parseFloat(lat), parseFloat(lng), id);
						}
					});
				});
			}
		});
	});

	closeDetail.addEventListener('click', () => {
		groupDetail.classList.add('hidden');
		listsView.classList.remove('hidden');
		listsHeader.classList.remove('hidden');
	});
</script>
