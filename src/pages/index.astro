---
import Layout from '../layouts/Layout.astro';
import CampusMap from '../components/CampusMap.astro';
import { db, Groups, Plants } from 'astro:db';
import { Image, getImage } from 'astro:assets';

const groupsData = await db.select().from(Groups);
const plantsData = await db.select().from(Plants);

const groups = await Promise.all(groupsData.map(async (group) => {
  const plantsInGroup = plantsData
    .filter(p => p.groupId === group.id)
    .sort((a, b) => a.scientificName.localeCompare(b.scientificName));
  
  const plantsWithOptimizedImages = await Promise.all(plantsInGroup.map(async (plant) => {
    let optimizedImageUrl = plant.imageUrl;
    if (plant.imageUrl) {
      try {
        const optimized = await getImage({ 
          src: plant.imageUrl, 
          width: 800, 
          format: 'webp',
          quality: 80
        });
        optimizedImageUrl = optimized.src;
      } catch (e) {
        console.error(`Failed to optimize image for ${plant.scientificName}:`, e);
      }
    }
    return { ...plant, optimizedImageUrl };
  }));

  const heroPlant = plantsInGroup.find(p => p.imageUrl);
  const heroImage = heroPlant ? heroPlant.imageUrl : null;
    
  return { ...group, plants: plantsWithOptimizedImages, heroImage };
}));
---

<Layout>
	<main class="pb-32 bg-forest-deep min-h-screen">
		<!-- Dynamic Top Navigation (Sticky) -->
		<nav class="sticky top-0 z-40 glass border-b-[0.5px] border-white/5 px-5 pt-12 pb-3 transition-all duration-300" id="top-nav">
			<div class="flex justify-between items-center mb-1">
				<span class="text-[13px] font-bold text-sage-light uppercase tracking-widest nav-header">Woody ID Discovery</span>
				<a href="/admin" class="text-sage-light text-sm font-semibold hover:opacity-70 transition-opacity nav-header">Admin</a>
			</div>
			<h1 class="large-title transition-all duration-300" id="nav-title">Library</h1>
		</nav>

		<!-- Library View -->
		<div id="lists-view" class="mt-6 px-4">
			<div class="space-y-6">
				{groups.map((group, index) => (
					<button 
						class="group-widget w-full relative h-48 rounded-[2rem] overflow-hidden shadow-2xl active:scale-[0.98] transition-all duration-300 animate-fade-up border border-sage-light/20 bg-forest-deep"
						style={`animation-delay: ${index * 100}ms`}
						data-group-id={group.id}
					>
						<!-- Hero Background Image -->
						{group.heroImage ? (
							<Image 
								src={group.heroImage} 
								width={800} 
								height={400} 
								format="webp"
								quality={80}
								class="absolute inset-0 w-full h-full object-cover grayscale-[0.2]" 
								alt={group.name} 
								loading="lazy"
							/>
						) : (
							<div class="absolute inset-0 bg-sage-muted" />
						)}
						
						<!-- Gradient Overlay -->
						<div class="absolute inset-0 bg-gradient-to-t from-forest-deep via-forest-deep/50 to-transparent" />
						
						<!-- Content -->
						<div class="absolute bottom-0 left-0 right-0 p-8 text-left">
							<div class="flex items-end justify-between">
								<div>
									<h2 class="text-3xl font-black text-cream-warm tracking-tight leading-none mb-3 font-header uppercase">{group.name}</h2>
									<div class="flex items-center gap-2">
										<span class="bg-forest-deep/60 text-cream-warm text-[10px] font-bold px-3 py-1.5 rounded-full border border-sage-light/30 uppercase tracking-widest nav-header">
											{group.plants.length} Species
										</span>
									</div>
								</div>
								<div class="w-12 h-12 rounded-full bg-cream-warm/10 backdrop-blur-md border border-cream-warm/20 flex items-center justify-center text-cream-warm">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
								</div>
							</div>
						</div>
					</button>
				))}
			</div>
			
			<!-- Branding/Footer Info -->
			<div class="mt-12 px-2 text-center pb-10">
				<p class="text-[12px] text-sage-light font-medium leading-relaxed uppercase tracking-[0.2em] nav-header">
					University of Georgia<br/>Woody Ornamentals Lab
				</p>
			</div>
		</div>

		<!-- Detail View -->
		<div id="group-detail" class="hidden fixed inset-0 z-50 bg-forest-deep overflow-y-auto no-scrollbar animate-in slide-in-from-right duration-300">
			<header class="sticky top-0 z-10 glass border-b-[0.5px] border-white/10 px-4 py-4 flex items-center justify-between">
				<button id="close-detail" class="text-cream-warm flex items-center gap-1 font-semibold nav-header">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					<span>Library</span>
				</button>
				<h2 id="header-detail-title" class="text-[17px] font-bold text-cream-warm truncate px-4 font-header uppercase"></h2>
				<div class="w-12"></div> <!-- Spacer -->
			</header>
			
			<div class="px-5 mt-8 mb-8">
				<h2 id="detail-title" class="large-title"></h2>
			</div>

			<div id="detail-list" class="space-y-6 px-4 pb-24">
				<!-- Plant cards injected here -->
			</div>
		</div>

		<!-- Study Hub View -->
		<div id="study-view" class="hidden mt-6 px-4 pb-32 overflow-y-auto no-scrollbar h-full">
			<div class="mb-8">
				<h3 class="text-[10px] font-black text-sage-light uppercase tracking-[0.3em] mb-2 nav-header text-center">Learning Platform</h3>
				<h2 class="large-title text-center">Study Hub</h2>
			</div>

			<div class="grid grid-cols-1 gap-4">
				{groups.map((group, index) => (
					<button 
						class="study-group-card group w-full bg-sage-muted/30 border border-white/5 rounded-[2rem] p-6 flex items-center justify-between active:scale-[0.98] transition-all duration-300 animate-fade-up"
						style={`animation-delay: ${index * 100}ms`}
						data-group-id={group.id}
					>
						<div class="flex items-center gap-5 text-left">
							<div class="w-14 h-14 rounded-2xl overflow-hidden border border-white/10 shrink-0">
								{group.heroImage ? (
									<img src={group.heroImage} class="w-full h-full object-cover" />
								) : (
									<div class="w-full h-full bg-forest-deep" />
								)}
							</div>
							<div>
								<h3 class="text-lg font-black text-cream-warm font-header uppercase tracking-tight">{group.name}</h3>
								<p class="text-[10px] font-bold text-sage-light uppercase tracking-widest nav-header opacity-60">{group.plants.length} Species</p>
							</div>
						</div>
						<div class="w-10 h-10 rounded-full bg-cream-warm/5 flex items-center justify-center text-cream-warm border border-white/5">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
						</div>
					</button>
				))}
			</div>
		</div>

		<!-- Study Mode Selector -->
		<div id="study-mode-modal" class="hidden fixed inset-0 z-[80] bg-forest-deep/80 backdrop-blur-xl animate-in fade-in duration-300 flex items-center justify-center p-6">
			<div class="w-full max-w-md bg-forest-deep border border-white/10 rounded-[3rem] p-8 shadow-2xl animate-in slide-in-from-bottom duration-500">
				<h3 id="mode-selector-group-name" class="text-[10px] font-black text-sage-light uppercase tracking-[0.3em] mb-4 text-center nav-header">Collection Name</h3>
				<h2 class="text-3xl font-black text-cream-warm text-center mb-8 font-header uppercase">Choose Mode</h2>
				
				<div class="space-y-4">
					<button id="select-flashcards" class="w-full bg-cream-warm text-forest-deep py-6 rounded-2xl flex items-center justify-center gap-4 active:scale-95 transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
						<span class="text-[12px] font-black uppercase tracking-[0.2em] nav-header">Flash Cards</span>
					</button>
					<button id="select-quiz" class="w-full bg-forest-deep border border-cream-warm/30 text-cream-warm py-6 rounded-2xl flex items-center justify-center gap-4 active:scale-95 transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
						<span class="text-[12px] font-black uppercase tracking-[0.2em] nav-header">Typing Quiz</span>
					</button>
					<button id="cancel-study" class="w-full py-4 text-sage-light/60 text-[10px] font-bold uppercase tracking-widest nav-header">Cancel</button>
				</div>
			</div>
		</div>

		<!-- Quiz View -->
		<div id="quiz-view" class="hidden fixed inset-0 z-[70] bg-forest-deep overflow-hidden flex flex-col animate-in fade-in duration-300">
			<header class="glass border-b-[0.5px] border-white/10 px-4 py-4 flex items-center justify-between shrink-0">
				<button id="close-quiz" class="text-cream-warm flex items-center gap-1 font-semibold nav-header">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					<span>Back</span>
				</button>
				<div class="flex bg-white/5 p-1 rounded-full border border-white/10" id="quiz-mode-toggle">
					<button class="px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest transition-all bg-cream-warm text-forest-deep" data-mode="sci-to-com">Sci → Com</button>
					<button class="px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest transition-all text-cream-warm/60" data-mode="com-to-sci">Com → Sci</button>
				</div>
				<div class="w-12"></div>
			</header>

			<div class="flex-grow flex flex-col items-center justify-start pt-12 px-6 relative overflow-y-auto no-scrollbar">
				<!-- Quiz Progress -->
				<div class="mb-8 text-center w-full">
					<span id="quiz-progress" class="text-[11px] font-bold text-sage-light uppercase tracking-[0.2em] nav-header">Question 1 of 12</span>
					<div class="w-full max-w-xs h-1 bg-white/5 rounded-full mt-3 mx-auto overflow-hidden">
						<div id="quiz-progress-bar" class="h-full bg-cream-warm transition-all duration-500 w-0"></div>
					</div>
				</div>

				<!-- Question Card -->
				<div id="quiz-card" class="w-full max-w-md bg-sage-muted rounded-[2.5rem] border border-white/10 p-10 text-center shadow-2xl mb-10 transition-all duration-300">
					<h3 class="text-[10px] font-black text-sage-light uppercase tracking-[0.3em] mb-10 nav-header">What is the common name?</h3>
					<div id="quiz-question-text" class="text-3xl font-black text-cream-warm leading-tight font-header uppercase tracking-tight mb-8">Quercus alba</div>
					
					<!-- Answer Input -->
					<div class="relative mt-8">
						<input 
							type="text" 
							id="quiz-answer-input" 
							placeholder="Type answer..." 
							class="w-full bg-forest-deep/50 border-2 border-white/10 rounded-2xl px-6 py-5 text-cream-warm text-lg font-bold placeholder:text-white/10 focus:outline-none focus:border-cream-warm/50 transition-all text-center"
							autocomplete="off"
							autocorrect="off"
							autocapitalize="off"
							spellcheck="false"
						/>
						<div id="quiz-feedback-icon" class="absolute right-4 top-1/2 -translate-y-1/2 hidden scale-0 transition-transform">
							<!-- Icons injected -->
						</div>
					</div>

					<!-- Correction Reveal -->
					<div id="quiz-correction" class="mt-8 hidden animate-in slide-in-from-bottom duration-300">
						<p class="text-[10px] font-bold text-red-400 uppercase tracking-widest nav-header mb-3">Correct Answer:</p>
						<p id="quiz-correct-reveal" class="text-2xl font-black text-cream-warm font-header uppercase tracking-tight">White Oak</p>
					</div>
				</div>

				<!-- Quiz Button -->
				<button id="quiz-submit-btn" class="w-full max-w-xs bg-cream-warm text-forest-deep py-5 rounded-2xl text-[12px] font-black uppercase tracking-[0.2em] active:scale-95 transition-all shadow-xl nav-header mb-12">
					Submit Answer
				</button>
			</div>
		</div>

		<!-- Quiz Results View -->
		<div id="quiz-results-view" class="hidden fixed inset-0 z-[90] bg-forest-deep overflow-hidden flex flex-col items-center justify-center px-8 animate-in fade-in duration-500">
			<div class="w-full max-w-md text-center">
				<h3 class="text-[10px] font-black text-sage-light uppercase tracking-[0.3em] mb-6 nav-header">Quiz Completed</h3>
				<div class="relative w-48 h-48 mx-auto mb-8">
					<svg class="w-full h-full transform -rotate-90">
						<circle cx="96" cy="96" r="88" stroke="currentColor" stroke-width="12" fill="transparent" class="text-white/5" />
						<circle id="results-ring" cx="96" cy="96" r="88" stroke="currentColor" stroke-width="12" fill="transparent" stroke-dasharray="552.92" stroke-dashoffset="552.92" class="text-cream-warm transition-all duration-[1500ms] ease-out" />
					</svg>
					<div class="absolute inset-0 flex flex-col items-center justify-center">
						<span id="results-percent" class="text-5xl font-black text-cream-warm font-header tracking-tighter">0%</span>
					</div>
				</div>
				<h2 id="results-grade" class="text-3xl font-black text-cream-warm mb-4 font-header uppercase tracking-tight">Excellent!</h2>
				<p id="results-score-text" class="text-sage-light font-medium uppercase tracking-[0.2em] text-[11px] mb-12 nav-header">You got 10 of 12 correct</p>

				<div class="space-y-4">
					<button id="retry-missed-btn" class="hidden w-full bg-cream-warm text-forest-deep py-5 rounded-2xl flex items-center justify-center gap-4 active:scale-95 transition-all">
						<span class="text-[12px] font-black uppercase tracking-[0.2em] nav-header">Study Incorrect Answers</span>
					</button>
					<button id="quiz-restart-all" class="w-full bg-white/5 border border-white/10 text-cream-warm py-5 rounded-2xl flex items-center justify-center gap-4 active:scale-95 transition-all">
						<span class="text-[12px] font-black uppercase tracking-[0.2em] nav-header">Restart Full Quiz</span>
					</button>
					<button id="results-exit" class="w-full py-4 text-sage-light/60 text-[10px] font-bold uppercase tracking-widest nav-header">Back to Study Hub</button>
				</div>
			</div>
		</div>

		<!-- Flash Cards View -->
		<div id="flashcard-view" class="hidden fixed inset-0 z-[70] bg-forest-deep overflow-hidden flex flex-col animate-in fade-in duration-300">
			<header class="glass border-b-[0.5px] border-white/10 px-4 py-4 flex items-center justify-between shrink-0">
				<button id="close-flashcards" class="text-cream-warm flex items-center gap-1 font-semibold nav-header">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					<span>Back</span>
				</button>
				<div class="flex bg-white/5 p-1 rounded-full border border-white/10" id="study-mode-toggle">
					<button class="px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest transition-all bg-cream-warm text-forest-deep" data-mode="sci-to-com">Sci → Com</button>
					<button class="px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest transition-all text-cream-warm/60" data-mode="com-to-sci">Com → Sci</button>
				</div>
				<div class="w-12"></div> <!-- Spacer -->
			</header>

			<div class="flex-grow flex flex-col items-center justify-center px-6 relative">
				<!-- Progress -->
				<div class="absolute top-8 left-0 right-0 text-center">
					<span id="flashcard-progress" class="text-[11px] font-bold text-sage-light uppercase tracking-[0.2em] nav-header">1 of 12</span>
				</div>

				<!-- The Card Container (3D Context) -->
				<div id="flashcard-deck" class="w-full max-w-md aspect-[3/4] perspective-1000 cursor-pointer">
					<div id="flashcard-inner" class="relative w-full h-full transition-transform duration-500 transform-style-3d shadow-2xl">
						<!-- Front Side -->
						<div id="card-front" class="absolute inset-0 backface-hidden bg-sage-muted rounded-[2.5rem] border border-white/10 flex flex-col items-center justify-center p-8 text-center shadow-inner">
							<h3 class="text-[10px] font-black text-sage-light uppercase tracking-[0.3em] mb-8 nav-header">Study Mode</h3>
							<div id="card-front-text" class="text-3xl font-black text-cream-warm leading-tight font-header uppercase tracking-tight">Scientific Name</div>
							<div class="mt-12 text-cream-warm/30 animate-pulse">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
							</div>
						</div>
						<!-- Back Side -->
						<div id="card-back" class="absolute inset-0 backface-hidden bg-forest-deep rounded-[2.5rem] border border-cream-warm/20 flex flex-col items-center justify-center p-8 text-center rotate-y-180 overflow-hidden">
							<div id="card-back-image-container" class="absolute inset-0 opacity-20 grayscale pointer-events-none">
								<img id="card-back-image" src="" class="w-full h-full object-cover" />
							</div>
							<div class="relative z-10">
								<h3 class="text-[10px] font-black text-sage-light uppercase tracking-[0.3em] mb-8 nav-header">Correct Answer</h3>
								<div id="card-back-text" class="text-3xl font-black text-cream-warm leading-tight font-header uppercase tracking-tight mb-4">Common Name</div>
								<div id="card-back-family" class="text-[15px] font-medium text-sage-light italic uppercase tracking-widest nav-header opacity-70">Family Name</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Controls -->
				<div class="mt-12 flex items-center gap-8">
					<button id="prev-card" class="w-14 h-14 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-cream-warm active:scale-90 transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					</button>
					<button id="shuffle-cards" class="bg-forest-deep text-cream-warm px-8 py-4 rounded-full text-[12px] font-black uppercase tracking-[0.2em] border border-cream-warm/30 shadow-xl active:scale-95 transition-all flex items-center gap-3 nav-header">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/><path d="m18 2 4 4-4 4"/><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"/><path d="M22 18h-5.9c-1.3 0-2.6-.7-3.3-1.8l-.5-.8"/><path d="m18 14 4 4-4 4"/></svg>
						Shuffle
					</button>
					<button id="next-card" class="w-14 h-14 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-cream-warm active:scale-90 transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
					</button>
				</div>
			</div>
		</div>

		<!-- Maps View -->
		<div id="maps-view" class="hidden fixed inset-0 z-30 bg-forest-deep">
			<div class="h-full flex flex-col pt-safe">
				<div class="px-5 py-3 border-b-[0.5px] border-white/5 glass shrink-0">
					<h2 class="text-[17px] font-bold text-center text-cream-warm uppercase tracking-widest font-header">Campus Discovery</h2>
				</div>
				<div class="flex-grow">
					<CampusMap />
				</div>
			</div>
		</div>

		<!-- Mature iOS Tab Bar -->
		<nav class="fixed bottom-0 left-0 right-0 z-[60] glass border-t-[0.5px] border-white/5 pb-safe">
			<div class="flex h-16 max-w-lg mx-auto">
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1.5 transition-colors text-cream-warm" 
					data-view="lists"
				>
					<div class="p-1.5 rounded-xl transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
					</div>
					<span class="text-[10px] font-bold uppercase tracking-widest nav-header">Library</span>
				</button>
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1.5 transition-colors text-sage-light/60" 
					data-view="study"
				>
					<div class="p-1.5 rounded-xl transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
					</div>
					<span class="text-[10px] font-bold uppercase tracking-widest nav-header">Study</span>
				</button>
				<button 
					class="tab-btn flex-1 flex flex-col items-center justify-center gap-1.5 transition-colors text-sage-light/60" 
					data-view="maps"
				>
					<div class="p-1.5 rounded-xl transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
					</div>
					<span class="text-[10px] font-bold uppercase tracking-widest nav-header">Map</span>
				</button>
			</div>
		</nav>
	</main>
</Layout>

<script define:vars={{ groups }}>
	const tabButtons = document.querySelectorAll('.tab-btn');
	const listsView = document.getElementById('lists-view');
	const studyView = document.getElementById('study-view');
	const mapsView = document.getElementById('maps-view');
	const groupWidgets = document.querySelectorAll('.group-widget');
	const groupDetail = document.getElementById('group-detail');
	const detailTitle = document.getElementById('detail-title');
	const headerDetailTitle = document.getElementById('header-detail-title');
	const detailList = document.getElementById('detail-list');
	const closeDetail = document.getElementById('close-detail');

	// Flashcard Elements
	const flashcardView = document.getElementById('flashcard-view');
	const closeFlashcards = document.getElementById('close-flashcards');
	const studyModeToggle = document.getElementById('study-mode-toggle');
	const flashcardProgress = document.getElementById('flashcard-progress');
	const cardFrontText = document.getElementById('card-front-text');
	const cardBackText = document.getElementById('card-back-text');
	const cardBackFamily = document.getElementById('card-back-family');
	const cardBackImage = document.getElementById('card-back-image');
	const flashcardInner = document.getElementById('flashcard-inner');
	const prevCardBtn = document.getElementById('prev-card');
	const nextCardBtn = document.getElementById('next-card');
	const shuffleBtn = document.getElementById('shuffle-cards');

	// Study Hub Elements
	const studyModeModal = document.getElementById('study-mode-modal');
	const modeSelectorGroupName = document.getElementById('mode-selector-group-name');
	const selectFlashcards = document.getElementById('select-flashcards');
	const selectQuiz = document.getElementById('select-quiz');
	const cancelStudy = document.getElementById('cancel-study');
	const studyGroupCards = document.querySelectorAll('.study-group-card');

	// Quiz Elements
	const quizView = document.getElementById('quiz-view');
	const closeQuiz = document.getElementById('close-quiz');
	const quizModeToggle = document.getElementById('quiz-mode-toggle');
	const quizProgress = document.getElementById('quiz-progress');
	const quizProgressBar = document.getElementById('quiz-progress-bar');
	const quizCard = document.getElementById('quiz-card');
	const quizQuestionText = document.getElementById('quiz-question-text');
	const quizAnswerInput = document.getElementById('quiz-answer-input');
	const quizSubmitBtn = document.getElementById('quiz-submit-btn');
	const quizCorrection = document.getElementById('quiz-correction');
	const quizCorrectReveal = document.getElementById('quiz-correct-reveal');
	
	// Results Elements
	const quizResultsView = document.getElementById('quiz-results-view');
	const resultsPercent = document.getElementById('results-percent');
	const resultsRing = document.getElementById('results-ring');
	const resultsGrade = document.getElementById('results-grade');
	const resultsScoreText = document.getElementById('results-score-text');
	const retryMissedBtn = document.getElementById('retry-missed-btn');
	const quizRestartAll = document.getElementById('quiz-restart-all');
	const resultsExit = document.getElementById('results-exit');

	if (!listsView) {
		console.error('Critical elements missing!');
	}

	let currentGroupPlants = [];
	let currentFlashcards = [];
	let currentCardIndex = 0;
	let isFlipped = false;
	let studyMode = 'sci-to-com'; // sci-to-com or com-to-sci
	let activeStudyGroup = null;

	// Quiz State
	let quizQueue = [];
	let missedPlants = [];
	let quizScore = 0;
	let isAwaitingNext = false;

	const shuffleArray = (array) => {
		const newArray = [...array];
		for (let i = newArray.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[newArray[i], newArray[j]] = [newArray[j], newArray[i]];
		}
		return newArray;
	};

	// Flashcard Logic
	const updateCard = () => {
		if (currentFlashcards.length === 0) return;
		const plant = currentFlashcards[currentCardIndex];
		isFlipped = false;
		flashcardInner.classList.remove('rotate-y-180');
		
		if (studyMode === 'sci-to-com') {
			cardFrontText.textContent = plant.scientificName;
			cardBackText.textContent = plant.commonName;
		} else {
			cardFrontText.textContent = plant.commonName;
			cardBackText.textContent = plant.scientificName;
		}
		
		cardBackFamily.textContent = plant.family || '';
		cardBackImage.src = plant.imageUrl || '';
		flashcardProgress.textContent = `${currentCardIndex + 1} of ${currentFlashcards.length}`;
	};

	// Quiz Logic
	const startQuiz = (plants, isRetry = false) => {
		quizQueue = shuffleArray(plants);
		if (!isRetry) missedPlants = [];
		currentCardIndex = 0;
		quizScore = 0;
		isAwaitingNext = false;
		quizView.classList.remove('hidden');
		studyModeModal.classList.add('hidden');
		updateQuizQuestion();
	};

	const updateQuizQuestion = () => {
		const plant = quizQueue[currentCardIndex];
		isAwaitingNext = false;
		quizAnswerInput.value = '';
		quizAnswerInput.disabled = false;
		quizAnswerInput.classList.remove('border-green-500', 'border-red-500');
		quizCard.classList.remove('shake');
		quizCorrection.classList.add('hidden');
		quizSubmitBtn.textContent = 'Submit Answer';
		
		if (studyMode === 'sci-to-com') {
			quizQuestionText.textContent = plant.scientificName;
		} else {
			quizQuestionText.textContent = plant.commonName;
		}

		const progress = ((currentCardIndex) / quizQueue.length) * 100;
		quizProgressBar.style.width = `${progress}%`;
		quizProgress.textContent = `Question ${currentCardIndex + 1} of ${quizQueue.length}`;
		
		setTimeout(() => quizAnswerInput.focus(), 300);
	};

	const checkAnswer = () => {
		if (isAwaitingNext) {
			currentCardIndex++;
			if (currentCardIndex >= quizQueue.length) {
				showResults();
			} else {
				updateQuizQuestion();
			}
			return;
		}

		const plant = quizQueue[currentCardIndex];
		const userAns = quizAnswerInput.value.trim().toLowerCase();
		const correctAns = studyMode === 'sci-to-com' ? plant.commonName : plant.scientificName;
		
		quizAnswerInput.disabled = true;

		if (userAns === correctAns.toLowerCase()) {
			quizScore++;
			quizAnswerInput.classList.add('border-green-500');
			quizSubmitBtn.textContent = 'Correct! Next →';
			isAwaitingNext = true;
		} else {
			missedPlants.push(plant);
			quizAnswerInput.classList.add('border-red-500');
			quizCard.classList.add('shake');
			quizCorrectReveal.textContent = correctAns;
			quizCorrection.classList.remove('hidden');
			quizSubmitBtn.textContent = 'Got it, Next →';
			isAwaitingNext = true;
		}
	};

	const showResults = () => {
		const percent = Math.round((quizScore / quizQueue.length) * 100);
		resultsPercent.textContent = `${percent}%`;
		resultsScoreText.textContent = `You got ${quizScore} of ${quizQueue.length} correct`;
		
		// Circle Animation
		const offset = 552.92 - (552.92 * percent / 100);
		resultsRing.style.strokeDashoffset = offset.toString();

		if (percent === 100) resultsGrade.textContent = "Mastery!";
		else if (percent >= 80) resultsGrade.textContent = "Excellent!";
		else if (percent >= 50) resultsGrade.textContent = "Good Start!";
		else resultsGrade.textContent = "Keep Studying!";

		if (missedPlants.length > 0) {
			retryMissedBtn.classList.remove('hidden');
		} else {
			retryMissedBtn.classList.add('hidden');
		}

		quizResultsView.classList.remove('hidden');
		quizView.classList.add('hidden');
	};

	// Study Hub Handlers
	studyGroupCards.forEach(card => {
		card.addEventListener('click', () => {
			const gid = card.dataset.groupId;
			activeStudyGroup = groups.find(g => g.id === gid);
			modeSelectorGroupName.textContent = activeStudyGroup.name;
			studyModeModal.classList.remove('hidden');
		});
	});

	cancelStudy.addEventListener('click', () => studyModeModal.classList.add('hidden'));

	selectFlashcards.addEventListener('click', () => {
		currentGroupPlants = [...activeStudyGroup.plants];
		currentFlashcards = shuffleArray(currentGroupPlants);
		currentCardIndex = 0;
		flashcardView.classList.remove('hidden');
		studyModeModal.classList.add('hidden');
		updateCard();
	});

	selectQuiz.addEventListener('click', () => {
		startQuiz(activeStudyGroup.plants);
	});

	quizSubmitBtn.addEventListener('click', checkAnswer);
	quizAnswerInput.addEventListener('keypress', (e) => {
		if (e.key === 'Enter') checkAnswer();
	});

	retryMissedBtn.addEventListener('click', () => {
		const currentMissed = [...missedPlants];
		quizResultsView.classList.add('hidden');
		startQuiz(currentMissed, true);
	});

	quizRestartAll.addEventListener('click', () => {
		quizResultsView.classList.add('hidden');
		startQuiz(activeStudyGroup.plants);
	});

	resultsExit.addEventListener('click', () => {
		quizResultsView.classList.add('hidden');
	});

	// Existing Handlers
	closeFlashcards.addEventListener('click', () => flashcardView.classList.add('hidden'));
	closeQuiz.addEventListener('click', () => quizView.classList.add('hidden'));

	studyModeToggle.addEventListener('click', (e) => {
		const btn = e.target.closest('button');
		if (!btn) return;
		studyMode = btn.dataset.mode;
		[studyModeToggle, quizModeToggle].forEach(toggle => {
			toggle.querySelectorAll('button').forEach(b => {
				b.classList.remove('bg-cream-warm', 'text-forest-deep');
				b.classList.add('text-cream-warm/60');
				if (b.dataset.mode === studyMode) {
					b.classList.add('bg-cream-warm', 'text-forest-deep');
					b.classList.remove('text-cream-warm/60');
				}
			});
		});
		updateCard();
	});

	quizModeToggle.addEventListener('click', (e) => {
		const btn = e.target.closest('button');
		if (!btn) return;
		studyMode = btn.dataset.mode;
		[studyModeToggle, quizModeToggle].forEach(toggle => {
			toggle.querySelectorAll('button').forEach(b => {
				b.classList.remove('bg-cream-warm', 'text-forest-deep');
				b.classList.add('text-cream-warm/60');
				if (b.dataset.mode === studyMode) {
					b.classList.add('bg-cream-warm', 'text-forest-deep');
					b.classList.remove('text-cream-warm/60');
				}
			});
		});
		updateQuizQuestion();
	});

	flashcardInner.addEventListener('click', () => {
		isFlipped = !isFlipped;
		flashcardInner.classList.toggle('rotate-y-180', isFlipped);
	});

	prevCardBtn.addEventListener('click', (e) => {
		e.stopPropagation();
		currentCardIndex = (currentCardIndex - 1 + currentFlashcards.length) % currentFlashcards.length;
		updateCard();
	});

	nextCardBtn.addEventListener('click', (e) => {
		e.stopPropagation();
		currentCardIndex = (currentCardIndex + 1) % currentFlashcards.length;
		updateCard();
	});

	shuffleBtn.addEventListener('click', (e) => {
		e.stopPropagation();
		currentFlashcards = shuffleArray(currentGroupPlants);
		currentCardIndex = 0;
		updateCard();
	});

	const switchTab = (view) => {
		tabButtons.forEach(btn => {
			if (btn.dataset.view === view) {
				btn.classList.add('text-cream-warm');
				btn.classList.remove('text-sage-light/60');
			} else {
				btn.classList.remove('text-cream-warm');
				btn.classList.add('text-sage-light/60');
			}
		});

		[listsView, studyView, mapsView].forEach(v => v.classList.add('hidden'));
		document.getElementById('top-nav').classList.remove('hidden');

		if (view === 'lists') {
			listsView.classList.remove('hidden');
			document.getElementById('nav-title').textContent = 'Library';
		} else if (view === 'study') {
			studyView.classList.remove('hidden');
			document.getElementById('nav-title').textContent = 'Study';
		} else {
			mapsView.classList.remove('hidden');
			document.getElementById('top-nav').classList.add('hidden');
			groupDetail.classList.add('hidden');
			window.dispatchEvent(new Event('resize'));
		}
	};

	tabButtons.forEach(btn => {
		btn.addEventListener('click', () => switchTab(btn.dataset.view));
	});

	groupWidgets.forEach(widget => {
		widget.addEventListener('click', () => {
			const groupId = widget.dataset.groupId;
			const group = groups.find(g => g.id === groupId);
			
			if (group) {
				detailTitle.textContent = group.name;
				headerDetailTitle.textContent = group.name;
				groupDetail.classList.remove('hidden');
				document.body.classList.add('overflow-hidden');
				
				detailList.innerHTML = group.plants.map((plant) => `
					<div class="bg-sage-muted rounded-[2rem] overflow-hidden border border-sage-light/30 shadow-2xl transition-all">
						${plant.optimizedImageUrl ? `
							<button class="w-full h-72 bg-forest-deep overflow-hidden relative cursor-zoom-in" onclick="window.openLightbox('${plant.imageUrl}')">
								<img 
									src="${plant.optimizedImageUrl}" 
									class="w-full h-full object-cover" 
									loading="lazy" 
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-forest-deep/60 to-transparent"></div>
							</button>
						` : ''}
						<div class="p-8">
							<div class="flex items-start justify-between mb-8">
								<div class="min-w-0">
									<div class="text-[26px] font-black text-cream-warm leading-tight tracking-tight uppercase font-header">${plant.scientificName}</div>
									<div class="text-[17px] font-medium text-cream-warm/70 italic mt-2">${plant.commonName}</div>
								</div>
								${plant.latitude ? `
									<button 
										class="see-on-map-btn w-12 h-12 bg-cream-warm/10 border border-cream-warm/20 rounded-2xl flex items-center justify-center text-cream-warm active:scale-90 transition-all shrink-0"
										data-lat="${plant.latitude}"
										data-lng="${plant.longitude}"
										data-id="${plant.id}"
									>
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
									</button>
								` : ''}
							</div>

							<div class="space-y-4">
								${[
									{ label: 'Leaf Arrangement', val: plant.leafArrangement },
									{ label: 'Leaf Shape', val: plant.leafShape },
									{ label: 'Leaf Margin', val: plant.leafMargin },
									{ label: 'Bark Features', val: plant.bark },
									{ label: 'Flower', val: plant.flower },
									{ label: 'Fruit', val: plant.fruit },
									{ label: 'Family', val: plant.family }
								].filter(f => f.val).map(f => `
									<div class="flex items-baseline gap-6 border-b border-white/10 pb-3">
										<div class="w-32 shrink-0 text-[10px] font-black text-sage-light uppercase tracking-widest nav-header">${f.label}</div>
										<div class="text-[16px] text-cream-warm font-medium leading-snug">${f.val}</div>
									</div>
								`).join('')}
							</div>
						</div>
					</div>
				`).join('');
				
				groupDetail.scrollTo({ top: 0, behavior: 'instant' });

				document.querySelectorAll('.see-on-map-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						const { lat, lng, id } = btn.dataset;
						switchTab('maps');
						groupDetail.classList.add('hidden');
						document.body.classList.remove('overflow-hidden');
						if (window.focusPlant) {
							window.focusPlant(parseFloat(lat), parseFloat(lng), id);
						}
					});
				});
			}
		});
	});

	closeDetail.addEventListener('click', () => {
		groupDetail.classList.add('hidden');
		document.body.classList.remove('overflow-hidden');
	});

	// Dynamic nav effect
	window.addEventListener('scroll', () => {
		const nav = document.getElementById('top-nav');
		const title = document.getElementById('nav-title');
		if (window.scrollY > 40) {
			nav.classList.add('py-2');
			nav.classList.remove('pt-12', 'pb-3');
			title.style.fontSize = '20px';
		} else {
			nav.classList.remove('py-2');
			nav.classList.add('pt-12', 'pb-3');
			title.style.fontSize = '34px';
		}
	});
</script>
