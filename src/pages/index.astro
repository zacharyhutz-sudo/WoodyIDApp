---
import Layout from '../layouts/Layout.astro';
import CampusMap from '../components/CampusMap.astro';
import { db, Groups, Plants, eq } from 'astro:db';

const groupsData = await db.select().from(Groups);
const plantsData = await db.select().from(Plants);

// Reconstruct the grouped structure for the UI
// Sort plants by scientific name within their groups to maintain consistent numbering
const groups = groupsData.map(group => {
  const plantsInGroup = plantsData
    .filter(p => p.groupId === group.id)
    .sort((a, b) => a.scientificName.localeCompare(b.scientificName));
    
  return {
    ...group,
    plants: plantsInGroup
  };
});

const numberMap: Record<string, string> = {
  '01': 'One', '02': 'Two', '03': 'Three', '04': 'Four', '05': 'Five',
  '06': 'Six', '07': 'Seven', '08': 'Eight', '09': 'Nine', '10': 'Ten'
};

const getDisplayNumber = (name: string) => {
  const parts = name.split(' ');
  if (parts.length < 2) return name;
  const num = parts[1];
  return numberMap[num] || num;
};
---

<Layout>
	<main class="min-h-screen bg-stone-50 text-stone-900 font-sans pb-24 md:pb-12">
		<!-- Mobile Header -->
		<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-xl border-b border-stone-200 px-4 py-3 md:py-6">
			<div class="max-w-4xl mx-auto flex flex-col items-center gap-3">
				<div class="flex items-center gap-2">
					<div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center text-white">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
						</svg>
					</div>
					<h1 class="text-xl md:text-2xl font-black tracking-tight text-stone-800">Woody ID</h1>
				</div>
				
				<div class="inline-flex p-1 bg-stone-100 rounded-2xl border border-stone-200 w-full max-w-[280px]" id="view-toggle">
					<button 
						class="flex-1 px-4 py-2 rounded-xl text-xs font-bold transition-all bg-white shadow-sm text-stone-900 active:scale-95"
						data-view="lists"
					>
						Lists
					</button>
					<button 
						class="flex-1 px-4 py-2 rounded-xl text-xs font-bold transition-all text-stone-400 hover:text-stone-700 active:scale-95"
						data-view="maps"
					>
						Maps
					</button>
				</div>
			</div>
		</header>

		<!-- Lists View -->
		<div id="lists-view" class="max-w-4xl mx-auto px-4 py-6 md:py-10 space-y-10">
			<section id="group-grid-container">
				<h2 class="text-[10px] font-black uppercase tracking-widest text-stone-400 mb-6 px-1">Plant Inventory</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					{groups.map((group) => (
						<button 
							class="group-widget flex-none bg-white border border-stone-200 rounded-2xl p-5 md:p-6 shadow-sm hover:shadow-md active:scale-[0.98] transition-all text-left group"
							data-group-id={group.id}
						>
							<div class="flex flex-row items-center justify-between">
								<div>
									<span class="text-[10px] font-black text-green-600 uppercase tracking-widest bg-green-50 px-2 py-0.5 rounded">Group</span>
									<h3 class="text-2xl font-bold mt-2 group-hover:text-green-700 transition-colors">{getDisplayNumber(group.name)}</h3>
									<div class="text-xs text-stone-400 mt-1 font-medium italic">
										{group.plants.length} Study Species
									</div>
								</div>
								<div class="h-10 w-10 rounded-xl bg-stone-50 flex items-center justify-center text-stone-300 group-hover:bg-green-50 group-hover:text-green-600 transition-colors">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
									</svg>
								</div>
							</div>
						</button>
					))}
				</div>
			</section>

			<!-- Detail View Container (hidden by default) -->
			<div id="group-detail" class="hidden animate-in fade-in slide-in-from-bottom-6 duration-500">
				<div class="flex items-center justify-between mb-8 px-1">
					<div class="flex flex-col">
						<span class="text-[10px] font-black text-stone-400 uppercase tracking-widest mb-1">Viewing Collection</span>
						<h2 id="detail-title" class="text-3xl font-bold text-stone-800"></h2>
					</div>
					<button id="close-detail" class="w-10 h-10 bg-stone-100 rounded-full flex items-center justify-center text-stone-400 hover:bg-stone-200 transition-colors active:scale-90">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
						</svg>
					</button>
				</div>
				<div id="detail-list" class="space-y-4">
					<!-- Plants will be injected here -->
				</div>
			</div>
		</div>

		<!-- Maps View -->
		<div id="maps-view" class="hidden max-w-5xl mx-auto px-4 py-6 md:py-10">
			<div class="mb-8">
				<h2 class="text-3xl font-bold text-stone-800">Discovery Map</h2>
				<p class="text-stone-500 text-sm mt-1 leading-relaxed">Navigate campus to find and identify plants in real-time.</p>
			</div>
			<CampusMap />
		</div>
	</main>
</Layout>

<script define:vars={{ groups }}>
	const viewToggle = document.getElementById('view-toggle');
	const listsView = document.getElementById('lists-view');
	const mapsView = document.getElementById('maps-view');
	const groupGrid = document.getElementById('group-grid-container');
	const groupWidgets = document.querySelectorAll('.group-widget');
	const groupDetail = document.getElementById('group-detail');
	const detailTitle = document.getElementById('detail-title');
	const detailList = document.getElementById('detail-list');
	const closeDetail = document.getElementById('close-detail');

	const switchView = (view) => {
		viewToggle.querySelectorAll('button').forEach(btn => {
			btn.classList.remove('bg-white', 'shadow-sm', 'text-stone-900');
			btn.classList.add('text-stone-400');
		});
		const targetBtn = viewToggle.querySelector(`[data-view="${view}"]`);
		targetBtn.classList.add('bg-white', 'shadow-sm', 'text-stone-900');
		targetBtn.classList.remove('text-stone-400');

		if (view === 'lists') {
			listsView.classList.remove('hidden');
			mapsView.classList.add('hidden');
		} else {
			listsView.classList.add('hidden');
			mapsView.classList.remove('hidden');
			window.dispatchEvent(new Event('resize'));
		}
	};

	// Toggle between Lists and Maps
	viewToggle.addEventListener('click', (e) => {
		const button = e.target.closest('button');
		if (!button) return;
		switchView(button.dataset.view);
	});

	// Handle group selection
	groupWidgets.forEach(widget => {
		widget.addEventListener('click', () => {
			const groupId = widget.dataset.groupId;
			const group = groups.find(g => g.id === groupId);
			
			if (group) {
				detailTitle.textContent = group.name;
				groupGrid.classList.add('hidden');
				
				detailList.innerHTML = group.plants.map((plant, index) => `
					<div class="bg-white border border-stone-200 rounded-2xl p-5 shadow-sm hover:border-green-300 transition-all group/item overflow-hidden">
						<div class="flex flex-col md:flex-row gap-6">
							${plant.imageUrl ? `
								<div class="w-full md:w-32 h-40 md:h-32 shrink-0 rounded-xl overflow-hidden shadow-inner bg-stone-50">
									<img src="${plant.imageUrl}" class="w-full h-full object-cover group-hover/item:scale-110 transition-transform duration-500" />
								</div>
							` : ''}
							<div class="flex-grow min-w-0">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<div class="flex items-center gap-2 mb-1">
											<span class="text-[10px] font-black text-green-600 bg-green-50 px-1.5 py-0.5 rounded">${index + 1}</span>
											<div class="text-xl font-bold text-stone-800 leading-tight">${plant.scientificName}</div>
										</div>
										<div class="text-sm italic text-stone-500">${plant.family || ''} ${plant.family ? '•' : ''} ${plant.commonName}</div>
									</div>
									${plant.latitude ? `
										<button 
											class="see-on-map-btn flex flex-col items-center gap-1 text-blue-500 hover:text-blue-700 transition-colors active:scale-90"
											data-lat="${plant.latitude}"
											data-lng="${plant.longitude}"
											data-id="${plant.id}"
										>
											<div class="p-2 bg-blue-50 rounded-xl">
												<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
												</svg>
											</div>
											<span class="text-[8px] font-black uppercase tracking-tighter">See on Map</span>
										</button>
									` : ''}
								</div>
								
								<div class="grid grid-cols-2 md:grid-cols-3 gap-y-3 gap-x-6 mt-6 pt-6 border-t border-stone-50">
									${plant.bark ? `<div><span class="text-[8px] font-black uppercase text-stone-300 block mb-0.5 tracking-tighter">Bark</span><span class="text-[11px] text-stone-600 leading-tight">${plant.bark}</span></div>` : ''}
									${plant.leafArrangement ? `<div><span class="text-[8px] font-black uppercase text-stone-300 block mb-0.5 tracking-tighter">Arrangement</span><span class="text-[11px] text-stone-600 leading-tight">${plant.leafArrangement}</span></div>` : ''}
									${plant.fruit ? `<div><span class="text-[8px] font-black uppercase text-stone-300 block mb-0.5 tracking-tighter">Fruit</span><span class="text-[11px] text-stone-600 leading-tight">${plant.fruit}</span></div>` : ''}
								</div>
							</div>
						</div>
					</div>
				`).join('');
				
				groupDetail.classList.remove('hidden');
				groupDetail.scrollIntoView({ behavior: 'smooth', block: 'start' });

				// Attach events to new buttons
				document.querySelectorAll('.see-on-map-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						const { lat, lng, id } = btn.dataset;
						switchView('maps');
						if (window.focusPlant) {
							window.focusPlant(parseFloat(lat), parseFloat(lng), id);
						}
					});
				});
			}
		});
	});

	// Close detail view
	closeDetail.addEventListener('click', () => {
		groupDetail.classList.add('hidden');
		groupGrid.classList.remove('hidden');
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});
</script>
