---
import Layout from '../../layouts/Layout.astro';
import { db, Groups, Plants, eq } from 'astro:db';

// Simple "auth" check via cookie
const cookie = Astro.request.headers.get('cookie');
const isAuthenticated = cookie?.includes('auth=ugawoodies');

if (!isAuthenticated) return Astro.redirect('/admin');

const plants = await db.select().from(Plants);
---

<Layout title="Map Editor">
  <main class="h-screen bg-slate-100 flex flex-col overflow-hidden">
    <!-- Sophisticated Header -->
    <header class="bg-slate-900 border-b border-slate-800 p-4 flex justify-between items-center shrink-0 z-30 shadow-lg">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-slate-400 hover:text-white transition-colors p-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <h1 class="text-[17px] font-bold text-white tracking-tight">Map Curator</h1>
      </div>
      <div id="status-badge" class="hidden text-[10px] font-black bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 px-3 py-1 rounded-full uppercase tracking-widest animate-pulse">Syncing</div>
    </header>

    <!-- Main Workspace -->
    <div class="flex-grow relative flex flex-col md:flex-row overflow-hidden">
      
      <!-- Map Area -->
      <div class="flex-grow relative z-10 h-full order-1 md:order-2">
        <div id="admin-map" class="absolute inset-0"></div>
        
        <!-- Mobile Hint -->
        <div id="mobile-hint" class="md:hidden absolute top-4 left-1/2 -translate-x-1/2 z-20 bg-slate-900/90 backdrop-blur text-white text-[12px] px-6 py-2.5 rounded-full font-bold pointer-events-none transition-opacity duration-300 opacity-0 shadow-2xl border border-white/10">
          Tap map to drop pin
        </div>
      </div>

      <!-- Plant Picker Sheet/Sidebar -->
      <div 
        id="plant-panel"
        class="absolute bottom-0 left-0 right-0 md:relative md:w-85 z-20 bg-white md:bg-slate-50 border-t md:border-t-0 md:border-r border-slate-200 transition-all duration-500 ease-in-out h-[45vh] md:h-full flex flex-col shadow-[0_-20px_50px_rgba(0,0,0,0.15)] md:shadow-none order-2 md:order-1"
      >
        <!-- Drag Handle for Mobile -->
        <div class="md:hidden w-full h-8 flex items-center justify-center cursor-pointer shrink-0" id="panel-toggle">
          <div class="w-10 h-1.5 bg-slate-200 rounded-full"></div>
        </div>

        <!-- Search & Info -->
        <div class="px-6 py-4 border-b border-slate-100 flex flex-col gap-3 shrink-0">
           <div class="flex items-center justify-between">
             <h2 class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Inventory</h2>
             <span id="placed-count" class="text-[10px] font-black text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">0 / 0</span>
           </div>
           <div class="relative">
               <input type="text" id="plant-search" placeholder="Filter by name..." class="w-full pl-10 pr-4 py-2.5 bg-white md:bg-white border border-slate-200 rounded-xl text-[15px] outline-none focus:ring-2 focus:ring-emerald-100 focus:border-emerald-500 transition-all font-medium" />
               <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-4 top-1/2 -translate-y-1/2 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
               </svg>
           </div>
        </div>

        <!-- Scrollable List -->
        <div class="flex-grow overflow-y-auto p-4 no-scrollbar space-y-2" id="unplaced-list">
          {plants.sort((a,b) => a.scientificName.localeCompare(b.scientificName)).map(plant => (
            <button 
              class="plant-item w-full text-left p-4 rounded-2xl bg-white border border-slate-100 shadow-sm hover:border-emerald-500 hover:shadow-md transition-all group relative active:scale-[0.98]"
              data-id={plant.id}
              data-name={plant.scientificName}
              data-placed={plant.latitude ? 'true' : 'false'}
            >
              <div class="pr-10">
                <div class="text-[14px] font-bold text-slate-900 leading-tight group-data-[placed=true]:text-slate-400">{plant.scientificName}</div>
                <div class="text-[12px] text-slate-400 truncate group-data-[placed=true]:text-slate-300 italic font-medium">{plant.commonName}</div>
              </div>
              
              <div class="absolute right-4 top-1/2 -translate-y-1/2">
                {plant.latitude ? (
                  <div class="w-7 h-7 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                ) : (
                  <div class="w-7 h-7 rounded-full flex items-center justify-center text-slate-200 group-hover:text-emerald-500 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                  </div>
                )}
              </div>
            </button>
          ))}
        </div>

        <!-- Selection Active Bar -->
        <div id="selection-bar" class="hidden bg-emerald-600 text-white p-6 shrink-0 animate-in slide-in-from-bottom duration-300">
          <div class="flex items-center justify-between gap-4">
            <div class="min-w-0">
              <div class="text-[10px] font-black uppercase opacity-70 tracking-widest">Active Curator Mode</div>
              <div id="selected-plant-name" class="font-bold truncate text-[17px] mt-1"></div>
            </div>
            <button id="cancel-selection" class="px-5 py-2.5 bg-white/20 hover:bg-white/30 rounded-xl text-[13px] font-black uppercase tracking-widest transition-colors border border-white/20">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
  import L from 'leaflet';

  let selectedPlantId = null;
  let markers = new Map();
  const placedCountEl = document.getElementById('placed-count');
  const statusBadge = document.getElementById('status-badge');
  const mobileHint = document.getElementById('mobile-hint');
  const selectionBar = document.getElementById('selection-bar');
  const selectedNameEl = document.getElementById('selected-plant-name');
  const cancelBtn = document.getElementById('cancel-selection');
  const panel = document.getElementById('plant-panel');
  const panelToggle = document.getElementById('panel-toggle');

  const map = L.map('admin-map', { 
    zoomControl: false, 
    tap: true,
    preferCanvas: true 
  }).setView([33.948, -83.375], 17);
  
  L.control.zoom({ position: 'topright' }).addTo(map);
  
  L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Esri Satellite',
    maxZoom: 19
  }).addTo(map);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', { 
    subdomains: 'abcd', 
    maxZoom: 19 
  }).addTo(map);

  const updatePlacedCount = () => {
    const items = document.querySelectorAll('.plant-item');
    const placed = document.querySelectorAll('.plant-item[data-placed="true"]');
    placedCountEl.textContent = `${placed.length} / ${items.length}`;
  };

  const updateLocation = async (id, lat, lng) => {
    statusBadge.classList.remove('hidden');
    const formData = new FormData();
    formData.append('action', 'update-location');
    formData.append('id', id);
    formData.append('lat', lat);
    formData.append('lng', lng);
    
    try {
      await fetch(`/api/update-location`, { method: 'POST', body: formData });
      const plantEl = document.querySelector(`.plant-item[data-id="${id}"]`);
      if (plantEl) {
        plantEl.setAttribute('data-placed', 'true');
        const iconContainer = plantEl.querySelector('.absolute.right-4');
        if (iconContainer) {
            iconContainer.innerHTML = `<div class="w-7 h-7 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-500 animate-in zoom-in duration-300"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>`;
        }
      }
      updatePlacedCount();
    } catch (e) {
      console.error(e);
    } finally {
      setTimeout(() => statusBadge.classList.add('hidden'), 1000);
    }
  };

  const loadPins = async () => {
    try {
        const res = await fetch('/api/plants.json');
        const plants = await res.json();
        const markerGroup = L.featureGroup();
        
        plants.forEach(plant => {
          if (plant.latitude && plant.longitude) {
            const marker = L.marker([plant.latitude, plant.longitude], { 
                draggable: true,
                icon: L.divIcon({
                    className: 'custom-admin-marker',
                    html: `<div class="w-6 h-6 bg-emerald-600 border-2 border-white rounded-full shadow-lg"></div>`,
                    iconSize: [24, 24],
                    iconAnchor: [12, 12]
                })
            });
            marker.bindPopup(`<div class="font-bold text-[15px] p-1">${plant.scientificName}</div><div class="text-[11px] text-slate-400 px-1 pb-1">Drag to move</div>`);
            
            marker.on('dragend', async () => {
                const pos = marker.getLatLng();
                await updateLocation(plant.id, pos.lat, pos.lng);
            });
            
            markers.set(plant.id, marker);
            markerGroup.addLayer(marker);
          }
        });
        
        markerGroup.addTo(map);
        updatePlacedCount();
    } catch (err) {
        console.error("Failed to load pins:", err);
    }
  };

  loadPins();

  document.querySelectorAll('.plant-item').forEach(item => {
    item.addEventListener('click', () => {
      selectedPlantId = item.dataset.id;
      selectedNameEl.textContent = item.dataset.name;
      selectionBar.classList.remove('hidden');
      mobileHint.classList.remove('opacity-0');
      
      if (window.innerWidth < 768) {
        panel.style.height = '140px';
      }
      
      document.querySelectorAll('.plant-item').forEach(el => el.classList.remove('ring-2', 'ring-emerald-500', 'border-emerald-500'));
      item.classList.add('ring-2', 'ring-emerald-500', 'border-emerald-500');
    });
  });

  map.on('click', async (e) => {
    if (!selectedPlantId) return;
    
    const lat = e.latlng.lat;
    const lng = e.latlng.lng;
    const name = selectedNameEl.textContent;
    
    if (markers.has(selectedPlantId)) {
        markers.get(selectedPlantId).setLatLng(e.latlng);
    } else {
        const marker = L.marker([lat, lng], { 
            draggable: true,
            icon: L.divIcon({
                className: 'custom-admin-marker',
                html: `<div class="w-6 h-6 bg-emerald-600 border-2 border-white rounded-full shadow-lg"></div>`,
                iconSize: [24, 24],
                iconAnchor: [12, 12]
            })
        }).addTo(map);
        marker.bindPopup(`<div class="font-bold text-[15px] p-1">${name}</div><div class="text-[11px] text-slate-400 px-1 pb-1">Drag to move</div>`);
        marker.on('dragend', async () => {
            const pos = marker.getLatLng();
            await updateLocation(selectedPlantId, pos.lat, pos.lng);
        });
        markers.set(selectedPlantId, marker);
    }
    
    await updateLocation(selectedPlantId, lat, lng);
    cancelSelection();
  });

  const cancelSelection = () => {
    selectedPlantId = null;
    selectionBar.classList.add('hidden');
    mobileHint.classList.add('opacity-0');
    document.querySelectorAll('.plant-item').forEach(el => el.classList.remove('ring-2', 'ring-emerald-500', 'border-emerald-500'));
    if (window.innerWidth < 768) panel.style.height = '45vh';
  };

  cancelBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    cancelSelection();
  });

  panelToggle.addEventListener('click', () => {
    if (selectedPlantId || window.innerWidth >= 768) return;
    const currentHeight = panel.style.height;
    panel.style.height = (currentHeight === '85vh') ? '45vh' : '85vh';
  });

  document.getElementById('plant-search').addEventListener('input', (e) => {
    const term = e.target.value.toLowerCase();
    document.querySelectorAll('.plant-item').forEach(item => {
      const match = item.dataset.name.toLowerCase().includes(term);
      item.style.display = match ? 'block' : 'none';
    });
  });
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    border-radius: 16px !important;
    padding: 0 !important;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important;
  }
  .leaflet-popup-content {
      margin: 8px !important;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
