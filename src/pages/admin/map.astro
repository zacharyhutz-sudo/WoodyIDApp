---
import Layout from '../../layouts/Layout.astro';
import { db, Groups, Plants, eq } from 'astro:db';

// Simple "auth" check via cookie
const cookie = Astro.request.headers.get('cookie');
const isAuthenticated = cookie?.includes('auth=ugawoodies');

if (!isAuthenticated) return Astro.redirect('/admin');

const plants = await db.select().from(Plants);
---

<Layout>
  <main class="min-h-screen bg-stone-50 text-stone-900 font-sans flex flex-col">
    <header class="bg-white border-b border-stone-200 p-4 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-stone-400 hover:text-stone-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <h1 class="text-xl font-bold">Map Editor</h1>
      </div>
      <p class="text-xs text-stone-500 font-medium bg-stone-100 px-3 py-1 rounded-full">Drag pins to set plant locations</p>
    </header>

    <div class="flex-grow relative">
      <div id="admin-map" class="absolute inset-0 z-10"></div>
      
      <!-- Plant Picker Sidebar -->
      <div class="absolute top-4 left-4 z-20 w-72 max-h-[calc(100%-2rem)] bg-white/90 backdrop-blur shadow-2xl rounded-2xl border border-stone-200 flex flex-col overflow-hidden">
        <div class="p-4 border-b border-stone-100">
           <input type="text" id="plant-search" placeholder="Search plants..." class="w-full px-3 py-2 bg-stone-50 border border-stone-100 rounded-lg text-sm outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="flex-grow overflow-y-auto p-2 space-y-1" id="unplaced-list">
          {plants.map(plant => (
            <div 
              class="plant-item p-3 rounded-xl border border-transparent hover:border-blue-200 hover:bg-blue-50 cursor-move transition-all group"
              draggable="true"
              data-id={plant.id}
              data-name={plant.scientificName}
            >
              <div class="text-sm font-bold text-stone-800 truncate">{plant.scientificName}</div>
              <div class="text-[10px] text-stone-500 truncate">{plant.commonName}</div>
              {plant.latitude && <div class="mt-1 text-[9px] font-black text-green-600 uppercase tracking-tighter">✓ Placed</div>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </main>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
  import L from 'leaflet';

  const map = L.map('admin-map').setView([33.948, -83.375], 16);
  
  L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Esri Satellite'
  }).addTo(map);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', {
    subdomains: 'abcd',
    maxZoom: 20
  }).addTo(map);

  // Load existing pins
  const loadPins = async () => {
    const res = await fetch('/api/plants.json');
    const plants = await res.json();
    plants.forEach(plant => {
      if (plant.latitude && plant.longitude) {
        const marker = L.marker([plant.latitude, plant.longitude], {
          draggable: true,
          title: plant.scientificName
        }).addTo(map);

        marker.on('dragend', async () => {
          const pos = marker.getLatLng();
          updateLocation(plant.id, pos.lat, pos.lng);
        });
      }
    });
  };

  const updateLocation = async (id, lat, lng) => {
    const formData = new FormData();
    formData.append('action', 'update-location');
    formData.append('id', id);
    formData.append('lat', lat);
    formData.append('lng', lng);
    
    await fetch(`/api/update-location`, { method: 'POST', body: formData });
  };

  loadPins();

  // Handle dragging from list to map
  let draggedPlantId = null;
  document.querySelectorAll('.plant-item').forEach(item => {
    item.addEventListener('dragstart', (e) => {
      draggedPlantId = item.dataset.id;
    });
  });

  const mapDiv = document.getElementById('admin-map');
  mapDiv.addEventListener('dragover', (e) => e.preventDefault());
  mapDiv.addEventListener('drop', async (e) => {
    e.preventDefault();
    const rect = mapDiv.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    
    const latlng = map.containerPointToLatLng([x, y]);
    
    // Add marker immediately for feedback
    const marker = L.marker(latlng, { draggable: true }).addTo(map);
    
    // Save
    await updateLocation(draggedPlantId, latlng.lat, latlng.lng);
    location.reload(); // Refresh to update "Placed" status in list
  });
</script>
