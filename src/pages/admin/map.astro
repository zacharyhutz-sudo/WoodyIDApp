---
import Layout from '../../layouts/Layout.astro';
import { db, Groups, Plants, eq } from 'astro:db';

// Simple "auth" check via cookie
const cookie = Astro.request.headers.get('cookie');
const isAuthenticated = cookie?.includes('auth=ugawoodies');

if (!isAuthenticated) return Astro.redirect('/admin');

const plants = await db.select().from(Plants);
---

<Layout title="Map Editor">
  <main class="h-screen bg-[#F2F2F7] flex flex-col overflow-hidden">
    <header class="bg-white/80 backdrop-blur-xl border-b-[0.5px] border-[#C6C6C8] p-4 flex justify-between items-center shrink-0">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-[#007AFF] p-1 -ml-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <h1 class="text-[17px] font-bold">Map Editor</h1>
      </div>
      <div id="status-badge" class="hidden text-[10px] font-black bg-[#E8F5E9] text-[#4CAF50] px-2 py-1 rounded-full uppercase tracking-widest animate-pulse">Saving</div>
    </header>

    <div class="flex-grow relative flex flex-col md:flex-row">
      <div id="admin-map" class="flex-grow z-10 h-full"></div>
      
      <!-- Mobile Hint Bubble -->
      <div id="mobile-hint" class="md:hidden absolute top-4 left-1/2 -translate-x-1/2 z-20 bg-black/80 backdrop-blur text-white text-[12px] px-5 py-2 rounded-full font-medium pointer-events-none transition-opacity duration-300 opacity-0 shadow-2xl">
        Tap map to place plant
      </div>

      <!-- iOS Style Bottom Sheet -->
      <div 
        id="plant-panel"
        class="absolute bottom-0 left-0 right-0 md:relative md:w-80 z-20 bg-white/95 backdrop-blur-2xl border-t-[0.5px] md:border-t-0 md:border-l-[0.5px] border-[#C6C6C8] transition-all duration-500 ease-in-out h-[40vh] md:h-full flex flex-col shadow-[0_-10px_40px_rgba(0,0,0,0.1)] md:shadow-none"
      >
        <!-- iOS Grabber -->
        <div class="md:hidden w-full h-6 flex items-center justify-center cursor-pointer" id="panel-toggle">
          <div class="w-9 h-1.25 bg-[#C6C6C8] rounded-full"></div>
        </div>

        <div class="px-5 py-2 border-b-[0.5px] border-[#F2F2F7] flex flex-col gap-2 shrink-0">
           <div class="flex items-center justify-between">
             <h2 class="text-[13px] font-semibold text-[#8E8E93] uppercase tracking-tight">Inventory</h2>
             <span id="placed-count" class="text-[11px] font-bold text-[#8E8E93] bg-[#F2F2F7] px-2 py-0.5 rounded-full">0 / 0</span>
           </div>
           <input type="text" id="plant-search" placeholder="Search plants..." class="w-full px-4 py-2 bg-[#F2F2F7] rounded-xl text-[15px] outline-none focus:ring-2 focus:ring-[#007AFF]/20 transition-all" />
        </div>

        <div class="flex-grow overflow-y-auto p-2 bg-[#F2F2F7]/30" id="unplaced-list">
          {plants.map(plant => (
            <button 
              class="plant-item w-full text-left p-4 rounded-xl bg-white border-[0.5px] border-[#C6C6C8] shadow-sm hover:border-[#007AFF] transition-all group relative active:scale-[0.98] mb-2"
              data-id={plant.id}
              data-name={plant.scientificName}
              data-placed={plant.latitude ? 'true' : 'false'}
            >
              <div class="pr-8">
                <div class="text-[15px] font-semibold text-black leading-tight group-data-[placed=true]:text-[#8E8E93]">{plant.scientificName}</div>
                <div class="text-[12px] text-[#8E8E93] truncate group-data-[placed=true]:text-[#C4C4C6] italic">{plant.commonName}</div>
              </div>
              
              <div class="absolute right-4 top-1/2 -translate-y-1/2">
                {plant.latitude ? (
                  <div class="text-[#34C759]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                ) : (
                  <div class="text-[#C4C4C6] group-hover:text-[#007AFF]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                  </div>
                )}
              </div>
            </button>
          ))}
        </div>

        <!-- Selection Active Bar -->
        <div id="selection-bar" class="hidden bg-[#007AFF] text-white p-5 shrink-0 animate-in slide-in-from-bottom duration-300">
          <div class="flex items-center justify-between gap-4">
            <div class="min-w-0">
              <div class="text-[11px] uppercase font-bold opacity-70 tracking-widest">Placing Species</div>
              <div id="selected-plant-name" class="font-bold truncate text-[17px]"></div>
            </div>
            <button id="cancel-selection" class="px-4 py-2 bg-white/20 hover:bg-white/30 rounded-full text-[13px] font-bold transition-colors">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
  import L from 'leaflet';

  let selectedPlantId = null;
  let markers = new Map();
  const placedCountEl = document.getElementById('placed-count');
  const statusBadge = document.getElementById('status-badge');
  const mobileHint = document.getElementById('mobile-hint');
  const selectionBar = document.getElementById('selection-bar');
  const selectedNameEl = document.getElementById('selected-plant-name');
  const cancelBtn = document.getElementById('cancel-selection');
  const panel = document.getElementById('plant-panel');
  const panelToggle = document.getElementById('panel-toggle');

  const map = L.map('admin-map', { zoomControl: false, tap: true }).setView([33.948, -83.375], 17);
  L.control.zoom({ position: 'topright' }).addTo(map);
  
  L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Esri Satellite'
  }).addTo(map);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', { subdomains: 'abcd', maxZoom: 20 }).addTo(map);

  const updatePlacedCount = () => {
    const total = document.querySelectorAll('.plant-item').length;
    const placed = document.querySelectorAll('.plant-item[data-placed="true"]').length;
    placedCountEl.textContent = `${placed} / ${total}`;
  };

  const updateLocation = async (id, lat, lng) => {
    statusBadge.classList.remove('hidden');
    const formData = new FormData();
    formData.append('action', 'update-location');
    formData.append('id', id);
    formData.append('lat', lat);
    formData.append('lng', lng);
    
    try {
      await fetch(`/api/update-location`, { method: 'POST', body: formData });
      const plantEl = document.querySelector(`.plant-item[data-id="${id}"]`);
      if (plantEl) {
        plantEl.setAttribute('data-placed', 'true');
        const iconContainer = plantEl.querySelector('.absolute.right-4');
        iconContainer.innerHTML = `<div class="text-[#34C759] animate-in zoom-in duration-300"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>`;
        plantEl.querySelector('.text-[15px]').classList.add('text-[#8E8E93]');
      }
      updatePlacedCount();
    } catch (e) {
      alert("Error saving location.");
    } finally {
      setTimeout(() => statusBadge.classList.add('hidden'), 1000);
    }
  };

  const loadPins = async () => {
    const res = await fetch('/api/plants.json');
    const plants = await res.json();
    plants.forEach(plant => {
      if (plant.latitude && plant.longitude) {
        addMarker(plant.id, plant.latitude, plant.longitude, plant.scientificName);
      }
    });
    updatePlacedCount();
  };

  const addMarker = (id, lat, lng, name) => {
    if (markers.has(id)) map.removeLayer(markers.get(id));
    const marker = L.marker([lat, lng], { draggable: true }).addTo(map);
    marker.bindPopup(`<div class="font-bold text-[15px]">${name}</div><div class="text-[11px] text-[#8E8E93]">Drag to move</div>`);
    marker.on('dragend', async () => {
      const pos = marker.getLatLng();
      await updateLocation(id, pos.lat, pos.lng);
    });
    markers.set(id, marker);
    return marker;
  };

  loadPins();

  document.querySelectorAll('.plant-item').forEach(item => {
    item.addEventListener('click', () => {
      selectedPlantId = item.dataset.id;
      selectedNameEl.textContent = item.dataset.name;
      selectionBar.classList.remove('hidden');
      mobileHint.classList.remove('opacity-0');
      if (window.innerWidth < 768) panel.style.height = '140px';
      document.querySelectorAll('.plant-item').forEach(el => el.classList.remove('ring-2', 'ring-[#007AFF]'));
      item.classList.add('ring-2', 'ring-[#007AFF]');
    });
  });

  map.on('click', async (e) => {
    if (!selectedPlantId) return;
    addMarker(selectedPlantId, e.latlng.lat, e.latlng.lng, selectedNameEl.textContent);
    await updateLocation(selectedPlantId, e.latlng.lat, e.latlng.lng);
    cancelSelection();
  });

  const cancelSelection = () => {
    selectedPlantId = null;
    selectionBar.classList.add('hidden');
    mobileHint.classList.add('opacity-0');
    document.querySelectorAll('.plant-item').forEach(el => el.classList.remove('ring-2', 'ring-[#007AFF]'));
    if (window.innerWidth < 768) panel.style.height = '40vh';
  };

  cancelBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    cancelSelection();
  });

  let isExpanded = false;
  panelToggle.addEventListener('click', () => {
    if (selectedPlantId) return;
    isExpanded = !isExpanded;
    panel.style.height = isExpanded ? '85vh' : '40vh';
  });

  document.getElementById('plant-search').addEventListener('input', (e) => {
    const term = e.target.value.toLowerCase();
    document.querySelectorAll('.plant-item').forEach(item => {
      const match = item.dataset.name.toLowerCase().includes(term);
      item.style.display = match ? 'block' : 'none';
    });
  });
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    border-radius: 14px !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
</style>
