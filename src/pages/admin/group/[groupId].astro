---
import Layout from '../../../layouts/Layout.astro';
import { db, Groups, Plants, eq } from 'astro:db';

const { groupId } = Astro.params;

// Simple "auth" check via cookie
const cookie = Astro.request.headers.get('cookie');
const isAuthenticated = cookie?.includes('auth=ugawoodies');

if (!isAuthenticated) return Astro.redirect('/admin');

const group = (await db.select().from(Groups).where(eq(Groups.id, groupId as string)))[0];
if (!group) return Astro.redirect('/admin');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'add-plant') {
    await db.insert(Plants).values({
      id: crypto.randomUUID(),
      groupId: group.id,
      scientificName: formData.get('scientificName') as string,
      commonName: formData.get('commonName') as string,
      family: formData.get('family') as string,
      imageUrl: formData.get('imageUrl') as string,
      leafArrangement: formData.get('leafArrangement') as string,
      leafMargin: formData.get('leafMargin') as string,
      leafShape: formData.get('leafShape') as string,
      leafBase: formData.get('leafBase') as string,
      leafApex: formData.get('leafApex') as string,
      bark: formData.get('bark') as string,
      flower: formData.get('flower') as string,
      fruit: formData.get('fruit') as string,
    });
  }
  
  if (action === 'delete-plant') {
    const id = formData.get('id') as string;
    await db.delete(Plants).where(eq(Plants.id, id));
  }
}

const plants = await db.select().from(Plants).where(eq(Plants.groupId, group.id));
---

<Layout title={`Managing ${group.name}`}>
  <main class="min-h-screen pt-12 pb-24 px-5 max-w-3xl mx-auto">
    <header class="mb-8">
      <a href="/admin" class="text-[#007AFF] flex items-center -ml-2 mb-4 font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span>Dashboard</span>
      </a>
      <h1 class="large-title">{group.name}</h1>
      <p class="text-[#8E8E93] text-[15px] mt-1 uppercase tracking-tight font-semibold">{plants.length} Species Cataloged</p>
    </header>

    <div class="space-y-10">
      <!-- Add Plant Form Section -->
      <section class="space-y-2">
        <h2 class="text-[13px] font-semibold text-[#8E8E93] uppercase tracking-tight px-4 ml-1">Add New Species</h2>
        <div class="bg-white rounded-xl overflow-hidden border-[0.5px] border-[#C6C6C8] p-4">
          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="add-plant" />
            
            <div class="space-y-3">
              <input name="scientificName" required placeholder="Scientific Name" class="w-full px-4 py-2.5 bg-[#F2F2F7] rounded-xl text-[15px] outline-none" />
              <input name="commonName" required placeholder="Common Name" class="w-full px-4 py-2.5 bg-[#F2F2F7] rounded-xl text-[15px] outline-none" />
              <input name="family" placeholder="Family" class="w-full px-4 py-2.5 bg-[#F2F2F7] rounded-xl text-[15px] outline-none" />
              <input name="imageUrl" placeholder="Image URL (https://...)" class="w-full px-4 py-2.5 bg-[#F2F2F7] rounded-xl text-[15px] outline-none" />
            </div>

            <details class="group/features">
              <summary class="list-none text-[#007AFF] text-[13px] font-bold uppercase tracking-widest flex items-center gap-2 cursor-pointer py-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-open/features:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
                </svg>
                Identification Features
              </summary>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4">
                {[
                  { key: 'leafArrangement', label: 'Leaf Arrangement' },
                  { key: 'leafMargin', label: 'Leaf Margin' },
                  { key: 'leafShape', label: 'Leaf Shape' },
                  { key: 'leafBase', label: 'Leaf Base' },
                  { key: 'leafApex', label: 'Leaf Apex' },
                  { key: 'bark', label: 'Bark' },
                  { key: 'flower', label: 'Flower' },
                  { key: 'fruit', label: 'Fruit' }
                ].map(feat => (
                  <input name={feat.key} placeholder={feat.label} class="w-full px-3 py-2 bg-[#F2F2F7] rounded-lg text-[14px] outline-none" />
                ))}
              </div>
            </details>

            <button type="submit" class="w-full bg-[#34C759] text-white font-bold py-3.5 rounded-xl active:opacity-70 transition-opacity mt-4">
              Add to Collection
            </button>
          </form>
        </div>
      </section>

      <!-- Species List Section -->
      <section class="space-y-2">
        <h2 class="text-[13px] font-semibold text-[#8E8E93] uppercase tracking-tight px-4 ml-1">Species List</h2>
        <div class="bg-white rounded-xl overflow-hidden border-[0.5px] border-[#C6C6C8]">
          {plants.map(plant => (
            <div class="flex items-center justify-between py-3 px-4 active:bg-[#E5E5EA] border-b-[0.5px] border-[#C6C6C8] last:border-0">
              <div class="min-w-0 flex-grow pr-4">
                <div class="text-[17px] text-black leading-tight font-medium truncate">{plant.scientificName}</div>
                <div class="text-[13px] text-[#8E8E93] truncate italic">{plant.commonName}</div>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                {plant.latitude && <div class="w-6 h-6 bg-[#E8F5E9] rounded-full flex items-center justify-center text-[#4CAF50]"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>}
                <form method="POST" onsubmit="return confirm('Permanently remove this plant?')">
                  <input type="hidden" name="action" value="delete-plant" />
                  <input type="hidden" name="id" value={plant.id} />
                  <button type="submit" class="w-8 h-8 flex items-center justify-center text-[#FF3B30] active:scale-90 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  </button>
                </form>
              </div>
            </div>
          ))}
          {plants.length === 0 && (
            <div class="p-12 text-center text-[#8E8E93] italic">No plants in this collection.</div>
          )}
        </div>
      </section>
    </div>
  </main>
</Layout>
