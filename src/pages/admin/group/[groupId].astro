---
import Layout from '../../../layouts/Layout.astro';
import { db, Groups, Plants, eq } from 'astro:db';

const { groupId } = Astro.params;

// Simple "auth" check via cookie
const cookie = Astro.request.headers.get('cookie');
const isAuthenticated = cookie?.includes('auth=ugawoodies');

if (!isAuthenticated) {
  return Astro.redirect('/admin');
}

const group = (await db.select().from(Groups).where(eq(Groups.id, groupId as string)))[0];
if (!group) return Astro.redirect('/admin');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'add-plant') {
    await db.insert(Plants).values({
      id: crypto.randomUUID(),
      groupId: group.id,
      scientificName: formData.get('scientificName') as string,
      commonName: formData.get('commonName') as string,
      family: formData.get('family') as string,
      imageUrl: formData.get('imageUrl') as string,
      leafArrangement: formData.get('leafArrangement') as string,
      leafMargin: formData.get('leafMargin') as string,
      leafShape: formData.get('leafShape') as string,
      leafBase: formData.get('leafBase') as string,
      leafApex: formData.get('leafApex') as string,
      bark: formData.get('bark') as string,
      flower: formData.get('flower') as string,
      fruit: formData.get('fruit') as string,
    });
  }
  
  if (action === 'delete-plant') {
    const id = formData.get('id') as string;
    await db.delete(Plants).where(eq(Plants.id, id));
  }
}

const plants = await db.select().from(Plants).where(eq(Plants.groupId, group.id));
---

<Layout title={`Managing ${group.name}`}>
  <main class="min-h-screen bg-stone-50 text-stone-900 font-sans p-4 md:p-12 pb-24 md:pb-12">
    <div class="max-w-5xl mx-auto">
      <header class="mb-8 md:mb-12">
        <a href="/admin" class="inline-flex items-center text-xs font-bold text-stone-400 hover:text-green-600 transition-colors uppercase tracking-widest mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
          Dashboard
        </a>
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-stone-800">{group.name}</h1>
        <div class="flex items-center gap-2 mt-2">
          <span class="px-2 py-0.5 bg-stone-200 text-stone-600 text-[10px] font-bold rounded uppercase tracking-tighter">ID: {group.id}</span>
          <p class="text-stone-500 text-sm">{plants.length} Species Cataloged</p>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8 items-start">
        <!-- Add Plant Form (Collapsible on Mobile) -->
        <div class="lg:col-span-1">
          <details class="bg-white rounded-2xl md:rounded-3xl border border-stone-200 shadow-sm overflow-hidden group/details lg:open" open>
            <summary class="lg:hidden list-none p-5 flex items-center justify-between cursor-pointer active:bg-stone-50 transition-colors">
              <div class="flex items-center gap-3">
                <div class="p-2 bg-green-50 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                </div>
                <h2 class="font-bold text-stone-800">Add New Plant</h2>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-stone-400 group-open/details:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>

            <div class="p-6 md:p-8 pt-0 lg:pt-8">
              <h2 class="hidden lg:block text-xl font-bold mb-6">Add New Plant</h2>
              <form method="POST" class="space-y-4">
                <input type="hidden" name="action" value="add-plant" />
                
                <div class="grid grid-cols-1 gap-4">
                  <div class="space-y-1">
                    <label class="text-[10px] font-black uppercase text-stone-400 px-1 tracking-widest">Scientific Name</label>
                    <input name="scientificName" required class="w-full px-4 py-2.5 bg-stone-50 border border-stone-200 rounded-xl outline-none focus:ring-2 focus:ring-green-500 transition-all" />
                  </div>

                  <div class="space-y-1">
                    <label class="text-[10px] font-black uppercase text-stone-400 px-1 tracking-widest">Common Name</label>
                    <input name="commonName" required class="w-full px-4 py-2.5 bg-stone-50 border border-stone-200 rounded-xl outline-none focus:ring-2 focus:ring-green-500 transition-all" />
                  </div>

                  <div class="grid grid-cols-2 gap-3">
                    <div class="space-y-1">
                      <label class="text-[10px] font-black uppercase text-stone-400 px-1 tracking-widest">Family</label>
                      <input name="family" class="w-full px-4 py-2 bg-stone-50 border border-stone-200 rounded-xl outline-none focus:ring-2 focus:ring-green-500 transition-all" />
                    </div>
                    <div class="space-y-1">
                      <label class="text-[10px] font-black uppercase text-stone-400 px-1 tracking-widest">Image URL</label>
                      <input name="imageUrl" placeholder="https://..." class="w-full px-4 py-2 bg-stone-50 border border-stone-200 rounded-xl outline-none focus:ring-2 focus:ring-green-500 transition-all" />
                    </div>
                  </div>
                </div>

                <div class="pt-6 mt-2 border-t border-stone-100">
                  <button type="button" id="toggle-features" class="flex items-center justify-between w-full text-left mb-4">
                    <h3 class="text-[10px] font-black text-stone-400 uppercase tracking-widest">Identification Features</h3>
                    <span class="text-stone-300">
                       <svg id="feature-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                       </svg>
                    </span>
                  </button>
                  
                  <div id="features-container" class="hidden grid grid-cols-1 gap-3">
                    {[
                      { key: 'leafArrangement', label: 'Leaf Arrangement' },
                      { key: 'leafMargin', label: 'Leaf Margin' },
                      { key: 'leafShape', label: 'Leaf Shape' },
                      { key: 'leafBase', label: 'Leaf Base' },
                      { key: 'leafApex', label: 'Leaf Apex' },
                      { key: 'bark', label: 'Bark' },
                      { key: 'flower', label: 'Flower' },
                      { key: 'fruit', label: 'Fruit' }
                    ].map(feat => (
                      <div class="space-y-1">
                        <label class="text-[9px] font-bold text-stone-400 px-1">{feat.label.toUpperCase()}</label>
                        <input name={feat.key} class="w-full px-3 py-2 bg-stone-50 border border-stone-200 rounded-lg text-sm outline-none focus:ring-2 focus:ring-green-500" />
                      </div>
                    ))}
                  </div>
                </div>

                <button type="submit" class="w-full bg-stone-900 text-white font-bold py-4 rounded-xl hover:bg-green-700 active:scale-[0.98] transition-all shadow-lg mt-4">
                  Add to Collection
                </button>
              </form>
            </div>
          </details>
        </div>

        <!-- Plant List -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl md:rounded-3xl border border-stone-200 shadow-sm overflow-hidden">
            <!-- Desktop Header -->
            <div class="hidden md:grid md:grid-cols-12 bg-stone-50/50 border-b border-stone-100 px-6 py-3">
               <div class="col-span-6 text-[10px] font-black uppercase text-stone-400">Species</div>
               <div class="col-span-4 text-[10px] font-black uppercase text-stone-400">Features</div>
               <div class="col-span-2 text-right"></div>
            </div>

            <div class="divide-y divide-stone-100">
              {plants.map(plant => (
                <div class="grid grid-cols-1 md:grid-cols-12 items-center px-6 py-4 hover:bg-stone-50 transition-colors gap-4">
                  <div class="md:col-span-6">
                    <div class="font-bold text-stone-800 text-base md:text-sm leading-tight">{plant.scientificName}</div>
                    <div class="text-sm text-stone-500 mt-0.5">{plant.commonName}</div>
                    <div class="text-[10px] italic text-stone-400 mt-1">{plant.family}</div>
                  </div>
                  <div class="md:col-span-4">
                    <div class="flex flex-wrap gap-1.5">
                      {plant.leafArrangement && <span class="px-2 py-0.5 bg-green-50 text-green-700 text-[9px] font-bold rounded-md uppercase">Leaf</span>}
                      {plant.bark && <span class="px-2 py-0.5 bg-amber-50 text-amber-700 text-[9px] font-bold rounded-md uppercase">Bark</span>}
                      {plant.fruit && <span class="px-2 py-0.5 bg-red-50 text-red-700 text-[9px] font-bold rounded-md uppercase">Fruit</span>}
                      {plant.latitude && <span class="px-2 py-0.5 bg-blue-50 text-blue-700 text-[9px] font-bold rounded-md uppercase tracking-tighter">📍 Map</span>}
                    </div>
                  </div>
                  <div class="md:col-span-2 text-right flex md:block justify-end">
                    <form method="POST" onsubmit="return confirm('Permanently remove this plant from the database?')">
                      <input type="hidden" name="action" value="delete-plant" />
                      <input type="hidden" name="id" value={plant.id} />
                      <button type="submit" class="p-2 md:p-0 text-stone-200 hover:text-red-500 transition-colors active:scale-90">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                      </button>
                    </form>
                  </div>
                </div>
              ))}
              {plants.length === 0 && (
                <div class="p-20 text-center flex flex-col items-center">
                  <div class="w-16 h-16 bg-stone-50 rounded-full flex items-center justify-center text-stone-200 mb-4">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                     </svg>
                  </div>
                  <p class="text-stone-400 italic text-sm">No species cataloged in this group yet.</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const toggleBtn = document.getElementById('toggle-features');
  const container = document.getElementById('features-container');
  const icon = document.getElementById('feature-icon');

  toggleBtn?.addEventListener('click', () => {
    const isHidden = container?.classList.contains('hidden');
    if (isHidden) {
      container?.classList.remove('hidden');
      icon?.classList.add('rotate-45');
    } else {
      container?.classList.add('hidden');
      icon?.classList.remove('rotate-45');
    }
  });
</script>
