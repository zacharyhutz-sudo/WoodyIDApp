---
import { db, Groups } from 'astro:db';

const groupsData = await db.select().from(Groups);
---

<div class="h-full flex flex-col bg-slate-50 relative">
  <!-- iOS Style Filter Bar -->
  <div class="px-4 py-3 glass border-b-[0.5px] border-slate-200 shrink-0 overflow-hidden z-20">
    <div class="flex overflow-x-auto gap-2 no-scrollbar" id="map-group-filter">
      <button 
        class="group-filter-btn px-4 py-2 rounded-full bg-emerald-700 text-white text-[12px] font-bold uppercase tracking-widest whitespace-nowrap transition-all shadow-sm"
        data-group="all"
      >
        All Species
      </button>
      {groupsData.map((group) => (
        <button 
          class="group-filter-btn px-4 py-2 rounded-full bg-white border-[0.5px] border-slate-200 text-slate-500 text-[12px] font-bold uppercase tracking-widest whitespace-nowrap transition-all shadow-sm"
          data-group={group.id}
        >
          {group.name}
        </button>
      ))}
    </div>
  </div>

  <div id="map-container" class="relative flex-grow">
    <div id="map" class="absolute inset-0 z-10"></div>
    
    <!-- Real-time Location Button (iOS Style) -->
    <button id="recenter-map" class="absolute bottom-24 right-5 z-20 w-12 h-12 glass rounded-2xl shadow-xl border-[0.5px] border-slate-200 flex items-center justify-center text-emerald-700 active:bg-slate-100 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
    </button>
  </div>

  <!-- iOS Style Full-Screen Detail Modal -->
  <div id="map-plant-modal" class="hidden fixed inset-0 z-[100] bg-slate-900/40 backdrop-blur-sm animate-in fade-in duration-200 p-4 flex items-end sm:items-center justify-center">
    <div class="bg-white w-full max-w-2xl max-h-[90vh] rounded-[2rem] shadow-2xl overflow-hidden flex flex-col animate-in slide-in-from-bottom duration-500 relative">
      <!-- Close Button -->
      <button id="close-map-modal" class="absolute top-5 right-5 z-20 w-10 h-10 bg-slate-900/10 backdrop-blur rounded-full flex items-center justify-center text-slate-800 hover:bg-slate-900/20 active:scale-90 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>

      <div class="overflow-y-auto no-scrollbar pb-10" id="map-modal-content">
        <!-- Content will be dynamically injected here -->
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('map');
  const groupFilter = document.getElementById('map-group-filter');
  const recenterBtn = document.getElementById('recenter-map');
  const modal = document.getElementById('map-plant-modal');
  const modalContent = document.getElementById('map-modal-content');
  const closeModal = document.getElementById('close-map-modal');
  
  if (mapElement) {
    const ugaCenter = [33.948, -83.375];
    const map = L.map('map', { zoomControl: false, tap: true, preferCanvas: true }).setView(ugaCenter, 17);

    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution: 'Esri Satellite'
    }).addTo(map);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', { subdomains: 'abcd', maxZoom: 20 }).addTo(map);

    // User Location
    let userPos = null;
    map.locate({setView: false, watch: true, enableHighAccuracy: true});
    const locationIcon = L.divIcon({
      className: 'user-location-marker',
      html: `<div class="w-4 h-4 bg-emerald-500 border-2 border-white rounded-full shadow-[0_0_15px_rgba(16,185,129,0.8)]"></div>`,
      iconSize: [16, 16],
      iconAnchor: [8, 8]
    });
    let locationMarker = null;
    map.on('locationfound', (e) => {
      userPos = e.latlng;
      if (!locationMarker) {
        locationMarker = L.marker(e.latlng, { icon: locationIcon }).addTo(map);
      } else {
        locationMarker.setLatLng(e.latlng);
      }
    });

    recenterBtn.addEventListener('click', () => {
      if (userPos) map.flyTo(userPos, 18);
    });

    // Marker Management
    const allMarkers = [];
    const markersByGroup = {};

    const createPlantIcon = (commonName, number) => L.divIcon({
      className: 'plant-marker',
      html: `
        <div class="flex flex-col items-center">
          <div class="bg-slate-900 px-2 py-1 rounded-lg border-[1px] border-white shadow-lg mb-1 whitespace-nowrap">
            <span class="text-[10px] font-black text-emerald-400 mr-1.5">${number}</span>
            <span class="text-[10px] font-bold text-white uppercase tracking-tighter">${commonName}</span>
          </div>
          <div class="w-4 h-4 bg-emerald-600 rounded-full border-2 border-white shadow-md"></div>
        </div>
      `,
      iconSize: [140, 60],
      iconAnchor: [70, 45]
    });

    // Modal Display Logic
    const showPlantDetail = (plant) => {
      modalContent.innerHTML = `
        <div class="w-full">
          <div class="w-full h-72 bg-slate-100 overflow-hidden relative">
            ${plant.imageUrl ? `<img src="${plant.imageUrl}" class="w-full h-full object-cover" />` : `
              <div class="w-full h-full flex items-center justify-center text-slate-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              </div>
            `}
            <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent"></div>
          </div>
          
          <div class="px-8 -mt-12 relative z-10">
            <div class="bg-white/80 backdrop-blur-xl p-6 rounded-3xl border-[0.5px] border-slate-100 shadow-xl mb-8">
              <div class="text-[10px] font-black text-emerald-600 uppercase tracking-[0.2em] mb-2">Species Discovery</div>
              <h2 class="text-3xl font-extrabold text-slate-900 leading-tight">${plant.scientificName}</h2>
              <h3 class="text-lg font-medium text-slate-400 italic mt-1">${plant.commonName}</h3>
            </div>

            <div class="space-y-6">
              <div class="grid grid-cols-1 gap-y-4">
                ${[
                  { label: 'Leaf Arrangement', val: plant.leafArrangement },
                  { label: 'Leaf Shape', val: plant.leafShape },
                  { label: 'Leaf Margin', val: plant.leafMargin },
                  { label: 'Bark Features', val: plant.bark },
                  { label: 'Flower', val: plant.flower },
                  { label: 'Fruit', val: plant.fruit },
                  { label: 'Family', val: plant.family }
                ].filter(f => f.val).map(f => `
                  <div class="flex items-baseline gap-6 border-b border-slate-50 pb-4">
                    <div class="w-28 shrink-0 text-[11px] font-black text-slate-300 uppercase tracking-widest">${f.label}</div>
                    <div class="text-[16px] text-slate-700 font-semibold leading-snug">${f.val}</div>
                  </div>
                `).join('')}
              </div>
            </div>
          </div>
        </div>
      `;
      modal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    };

    closeModal.addEventListener('click', () => {
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    });

    // Close on backdrop click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }
    });

    // Global Focus Function
    window.focusPlant = (lat, lng, id) => {
      map.flyTo([lat, lng], 19, { duration: 1.5 });
      // Fetch data for the modal
      fetch('/api/plants.json')
        .then(res => res.json())
        .then(plants => {
          const plant = plants.find(p => p.id === id);
          if (plant) {
            setTimeout(() => showPlantDetail(plant), 1600);
          }
        });
    };

    fetch('/api/plants.json')
      .then(res => res.json())
      .then(plants => {
        const sortedByGroup = {};
        plants.forEach(p => {
          if (!sortedByGroup[p.groupId]) sortedByGroup[p.groupId] = [];
          sortedByGroup[p.groupId].push(p);
        });
        
        Object.keys(sortedByGroup).forEach(gid => {
          sortedByGroup[gid].sort((a, b) => a.scientificName.localeCompare(b.scientificName));
        });

        plants.forEach(plant => {
          if (plant.latitude && plant.longitude) {
            const groupList = sortedByGroup[plant.groupId] || [];
            const plantNumber = groupList.findIndex(p => p.id === plant.id) + 1;
            
            const marker = L.marker([plant.latitude, plant.longitude], { 
              icon: createPlantIcon(plant.commonName, plantNumber) 
            });
            
            marker.plantId = plant.id;
            marker.groupId = plant.groupId;
            
            marker.on('click', () => {
              showPlantDetail(plant);
            });

            allMarkers.push(marker);
            if (!markersByGroup[plant.groupId]) markersByGroup[plant.groupId] = [];
            markersByGroup[plant.groupId].push(marker);
            
            marker.addTo(map);
          }
        });
      });

    groupFilter.addEventListener('click', (e) => {
      const btn = e.target.closest('button');
      if (!btn) return;

      const selectedGroup = btn.dataset.group;

      document.querySelectorAll('.group-filter-btn').forEach(b => {
        b.classList.remove('bg-emerald-700', 'text-white');
        b.classList.add('bg-white', 'text-slate-500');
      });
      btn.classList.add('bg-emerald-700', 'text-white');
      btn.classList.remove('bg-white', 'text-slate-50');

      allMarkers.forEach(m => map.removeLayer(m));
      
      if (selectedGroup === 'all') {
        allMarkers.forEach(m => m.addTo(map));
      } else {
        const groupMarkers = markersByGroup[selectedGroup] || [];
        groupMarkers.forEach(m => m.addTo(map));
        if (groupMarkers.length > 0) {
          const groupBounds = L.featureGroup(groupMarkers).getBounds();
          map.fitBounds(groupBounds, { padding: [50, 50] });
        }
      }
    });
  }
</script>

<style is:global>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
