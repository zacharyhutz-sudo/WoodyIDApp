---
import { db, Groups } from 'astro:db';

const groupsData = await db.select().from(Groups);
---

<div class="h-full flex flex-col bg-[#F2F2F7]">
  <!-- iOS Style Filter Bar -->
  <div class="px-4 py-3 bg-white/80 backdrop-blur-xl border-b-[0.5px] border-[#C6C6C8] shrink-0 overflow-hidden">
    <div class="flex overflow-x-auto gap-2 no-scrollbar" id="map-group-filter">
      <button 
        class="group-filter-btn px-4 py-1.5 rounded-full bg-[#007AFF] text-white text-[13px] font-semibold whitespace-nowrap transition-all"
        data-group="all"
      >
        All Plants
      </button>
      {groupsData.map((group) => (
        <button 
          class="group-filter-btn px-4 py-1.5 rounded-full bg-[#E5E5EA] text-[#8E8E93] text-[13px] font-semibold whitespace-nowrap transition-all"
          data-group={group.id}
        >
          {group.name}
        </button>
      ))}
    </div>
  </div>

  <div id="map-container" class="relative flex-grow">
    <div id="map" class="absolute inset-0 z-10"></div>
    
    <!-- Real-time Location Button (iOS Style) -->
    <button id="recenter-map" class="absolute bottom-24 right-5 z-20 w-11 h-11 bg-white/90 backdrop-blur rounded-xl shadow-lg border-[0.5px] border-[#C6C6C8] flex items-center justify-center text-[#007AFF] active:bg-[#F2F2F7] transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
    </button>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('map');
  const groupFilter = document.getElementById('map-group-filter');
  const recenterBtn = document.getElementById('recenter-map');
  
  if (mapElement) {
    const ugaCenter = [33.948, -83.375];
    const map = L.map('map', { zoomControl: false, tap: true }).setView(ugaCenter, 17);

    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution: 'Esri Satellite'
    }).addTo(map);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', {
      subdomains: 'abcd',
      maxZoom: 20
    }).addTo(map);

    // User Location
    let userPos = null;
    map.locate({setView: false, watch: true, enableHighAccuracy: true});
    const locationIcon = L.divIcon({
      className: 'user-location-marker',
      html: `<div class="w-4 h-4 bg-[#007AFF] border-2 border-white rounded-full shadow-lg"></div>`,
      iconSize: [16, 16],
      iconAnchor: [8, 8]
    });
    let locationMarker = null;
    map.on('locationfound', (e) => {
      userPos = e.latlng;
      if (!locationMarker) {
        locationMarker = L.marker(e.latlng, { icon: locationIcon }).addTo(map);
      } else {
        locationMarker.setLatLng(e.latlng);
      }
    });

    recenterBtn.addEventListener('click', () => {
      if (userPos) map.flyTo(userPos, 18);
    });

    // Marker Management
    const allMarkers = [];
    const markersByGroup = {};

    const createPlantIcon = (commonName, number) => L.divIcon({
      className: 'plant-marker',
      html: `
        <div class="flex flex-col items-center">
          <div class="bg-white px-2 py-0.5 rounded-full border-[0.5px] border-[#C6C6C8] shadow-md mb-1 whitespace-nowrap">
            <span class="text-[10px] font-bold text-[#34C759] mr-1">${number}</span>
            <span class="text-[10px] font-medium text-black">${commonName}</span>
          </div>
          <div class="w-5 h-5 bg-[#34C759] rounded-full border-2 border-white shadow-md"></div>
        </div>
      `,
      iconSize: [120, 60],
      iconAnchor: [60, 45],
      popupAnchor: [0, -40]
    });

    // Global Focus Function
    window.focusPlant = (lat, lng, id) => {
      map.flyTo([lat, lng], 19, { duration: 1.5 });
      const marker = allMarkers.find(m => m.plantId === id);
      if (marker) {
        setTimeout(() => marker.openPopup(), 1600);
      }
    };

    // Load Data
    fetch('/api/plants.json')
      .then(res => res.json())
      .then(plants => {
        const sortedByGroup = {};
        plants.forEach(p => {
          if (!sortedByGroup[p.groupId]) sortedByGroup[p.groupId] = [];
          sortedByGroup[p.groupId].push(p);
        });
        
        Object.keys(sortedByGroup).forEach(gid => {
          sortedByGroup[gid].sort((a, b) => a.scientificName.localeCompare(b.scientificName));
        });

        plants.forEach(plant => {
          if (plant.latitude && plant.longitude) {
            const groupList = sortedByGroup[plant.groupId] || [];
            const plantNumber = groupList.findIndex(p => p.id === plant.id) + 1;
            
            const marker = L.marker([plant.latitude, plant.longitude], { 
              icon: createPlantIcon(plant.commonName, plantNumber) 
            });
            
            marker.plantId = plant.id;
            marker.groupId = plant.groupId;
            
            marker.bindPopup(`
              <div class="min-w-[200px] font-sans">
                <div class="mb-2">
                    <div class="text-[11px] font-bold text-[#8E8E93] uppercase tracking-tighter">${plant.groupId}</div>
                    <div class="text-[17px] font-bold text-black leading-tight">${plant.scientificName}</div>
                    <div class="text-[13px] italic text-[#8E8E93]">${plant.commonName}</div>
                </div>
                ${plant.imageUrl ? `<img src="${plant.imageUrl}" class="w-full h-24 object-cover rounded-xl mb-3 shadow-inner" />` : ''}
                <div class="text-[11px] text-black leading-relaxed bg-[#F2F2F7] p-2 rounded-lg border-[0.5px] border-[#C6C6C8]">
                  ${plant.bark || plant.leafArrangement || 'Details in Library.'}
                </div>
              </div>
            `);

            allMarkers.push(marker);
            if (!markersByGroup[plant.groupId]) markersByGroup[plant.groupId] = [];
            markersByGroup[plant.groupId].push(marker);
            
            marker.addTo(map);
          }
        });
      });

    // Filter Logic
    groupFilter.addEventListener('click', (e) => {
      const btn = e.target.closest('button');
      if (!btn) return;

      const selectedGroup = btn.dataset.group;

      document.querySelectorAll('.group-filter-btn').forEach(b => {
        b.classList.remove('bg-[#007AFF]', 'text-white');
        b.classList.add('bg-[#E5E5EA]', 'text-[#8E8E93]');
      });
      btn.classList.add('bg-[#007AFF]', 'text-white');
      btn.classList.remove('bg-[#E5E5EA]', 'text-[#8E8E93]');

      allMarkers.forEach(m => map.removeLayer(m));
      
      if (selectedGroup === 'all') {
        allMarkers.forEach(m => m.addTo(map));
      } else {
        const groupMarkers = markersByGroup[selectedGroup] || [];
        groupMarkers.forEach(m => m.addTo(map));
        if (groupMarkers.length > 0) {
          const groupBounds = L.featureGroup(groupMarkers).getBounds();
          map.fitBounds(groupBounds, { padding: [50, 50] });
        }
      }
    });
  }
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    border-radius: 14px !important;
    padding: 2px !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.15) !important;
  }
  .leaflet-popup-tip-container {
    display: none !important;
  }
  .leaflet-popup-content {
    margin: 12px !important;
  }
</style>
