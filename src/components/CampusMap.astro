---
import { db, Groups } from 'astro:db';

const groupsData = await db.select().from(Groups);
---

<div class="h-full flex flex-col bg-forest-deep relative">
  <!-- iOS Style Filter Bar -->
  <div class="px-4 py-3 glass border-b-[0.5px] border-white/5 shrink-0 overflow-hidden z-20">
    <div class="flex overflow-x-auto gap-2 no-scrollbar" id="map-group-filter">
      {groupsData.map((group, index) => (
        <button 
          class={`group-filter-btn px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-widest whitespace-nowrap transition-all shadow-sm font-header ${index === 0 ? 'bg-forest-deep text-cream-warm border border-cream-warm/30' : 'bg-sage-muted/40 border border-white/10 text-cream-warm/60'}`}
          data-group={group.id}
        >
          {group.name}
        </button>
      ))}
    </div>
  </div>

  <div id="map-container" class="relative flex-grow">
    <div id="map" class="absolute inset-0 z-10"></div>
    
    <!-- Real-time Location Button (iOS Style) -->
    <button id="recenter-map" class="absolute bottom-24 right-5 z-20 w-12 h-12 glass rounded-2xl shadow-xl border-[0.5px] border-white/10 flex items-center justify-center text-cream-warm active:scale-95 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
    </button>
  </div>

  <!-- iOS Style Full-Screen Detail Modal -->
  <div id="map-plant-modal" class="hidden fixed inset-0 z-[100] bg-forest-deep/60 backdrop-blur-md animate-in fade-in duration-200 p-4 flex items-end sm:items-center justify-center">
    <div class="bg-forest-deep w-full max-w-2xl max-h-[90vh] rounded-[2rem] shadow-2xl border border-white/10 overflow-hidden flex flex-col animate-in slide-in-from-bottom duration-500 relative">
      <!-- Close Button -->
      <button id="close-map-modal" class="absolute top-5 right-5 z-20 w-10 h-10 bg-white/10 backdrop-blur rounded-full flex items-center justify-center text-cream-warm hover:bg-white/20 active:scale-90 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>

      <div class="overflow-y-auto no-scrollbar pb-10" id="map-modal-content">
        <!-- Content will be dynamically injected here -->
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('map');
  const groupFilter = document.getElementById('map-group-filter');
  const recenterBtn = document.getElementById('recenter-map');
  const modal = document.getElementById('map-plant-modal');
  const modalContent = document.getElementById('map-modal-content');
  const closeModal = document.getElementById('close-map-modal');
  
  if (mapElement) {
    const ugaCenter = [33.948, -83.375];
    const map = L.map('map', { 
      zoomControl: false, 
      tap: true, 
      preferCanvas: true,
      maxZoom: 19
    }).setView(ugaCenter, 17);

    // Create a dedicated pane for spider lines and dots to keep them below pins
    map.createPane('spiderPane');
    map.getPane('spiderPane').style.zIndex = '450'; // Above tiles (200), below markers (600)

    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution: 'Esri Satellite',
      maxZoom: 19
    }).addTo(map);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', { 
      subdomains: 'abcd', 
      maxZoom: 19 
    }).addTo(map);

    // User Location
    let userPos = null;
    map.locate({setView: false, watch: true, enableHighAccuracy: true});
    const locationIcon = L.divIcon({
      className: 'user-location-marker',
      html: `<div class="w-4 h-4 bg-red-500 border-2 border-white rounded-full shadow-[0_0_15px_rgba(239,68,68,0.8)] animate-pulse"></div>`,
      iconSize: [16, 16],
      iconAnchor: [8, 8]
    });
    let locationMarker = null;
    map.on('locationfound', (e) => {
      userPos = e.latlng;
      if (!locationMarker) {
        locationMarker = L.marker(e.latlng, { icon: locationIcon }).addTo(map);
      } else {
        locationMarker.setLatLng(e.latlng);
      }
    });

    recenterBtn.addEventListener('click', () => {
      if (userPos) map.flyTo(userPos, 18);
    });

    // Marker Management
    const markersByGroup = {};
    const groupLayers = L.layerGroup().addTo(map);

    const createPlantIcon = (number) => L.divIcon({
      className: 'plant-marker',
      html: `
        <div class="flex items-center justify-center w-8 h-8 bg-[#E7E2D6] rounded-full border-2 border-[#5E6F66] shadow-2xl transition-transform active:scale-95">
          <span class="text-[#2A3A34] font-black text-[13px] tracking-tighter font-header">${number}</span>
        </div>
      `,
      iconSize: [32, 32],
      iconAnchor: [16, 16]
    });

    const createTrunkIcon = () => L.divIcon({
      className: 'trunk-marker',
      html: `<div class="w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white shadow-lg"></div>`,
      iconSize: [10, 10],
      iconAnchor: [5, 5]
    });

    const getDistance = (lat1, lon1, lat2, lon2) => {
      const R = 6371e3; // meters
      const φ1 = lat1 * Math.PI/180;
      const φ2 = lat2 * Math.PI/180;
      const Δφ = (lat2-lat1) * Math.PI/180;
      const Δλ = (lon2-lon1) * Math.PI/180;
      const a = Math.sin(Δφ/2) * Math.sin(Δφ/2) +
                Math.cos(φ1) * Math.cos(φ2) *
                Math.sin(Δλ/2) * Math.sin(Δλ/2);
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
      return R * c;
    };

    const getBearing = (lat1, lon1, lat2, lon2) => {
      const y = Math.sin((lon2 - lon1) * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180);
      const x = Math.cos(lat1 * Math.PI / 180) * Math.sin(lat2 * Math.PI / 180) -
                Math.sin(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.cos((lon2 - lon1) * Math.PI / 180);
      return (Math.atan2(y, x) * 180 / Math.PI + 360) % 360;
    };

    const updateMapMarkers = (selectedGroupId) => {
        groupLayers.clearLayers();
        const plants = markersByGroup[selectedGroupId] || [];
        if (plants.length === 0) return;

        // Group plants by coordinates
        const proximityGroups = [];
        const threshold = 5.0; 

        plants.forEach(plant => {
            let foundGroup = proximityGroups.find(g => getDistance(plant.latitude, plant.longitude, g.lat, g.lng) < threshold);
            if (!foundGroup) {
                foundGroup = { lat: plant.latitude, lng: plant.longitude, members: [] };
                proximityGroups.push(foundGroup);
            }
            foundGroup.members.push(plant);
        });

        const activeMarkers = [];

        proximityGroups.forEach(group => {
            const count = group.members.length;
            const centerLat = group.members.reduce((sum, p) => sum + p.latitude, 0) / count;
            const centerLng = group.members.reduce((sum, p) => sum + p.longitude, 0) / count;

            if (count > 1) {
                L.marker([centerLat, centerLng], { 
                    icon: createTrunkIcon(), 
                    pane: 'spiderPane',
                    interactive: false 
                }).addTo(groupLayers);

                const obstacles = plants.filter(p => !group.members.includes(p) && getDistance(centerLat, centerLng, p.latitude, p.longitude) < 15);
                const obstacleBearings = obstacles.map(p => getBearing(centerLat, centerLng, p.latitude, p.longitude));

                let bestStartAngle = 0;
                let maxMinDistance = 0;
                
                for (let a = 0; a < 360; a += 15) {
                    let minDistanceToObstacle = 360;
                    group.members.forEach((_, i) => {
                        let angle = (a + (i / count) * 360) % 360;
                        if (count === 2 && i === 1) angle = (a + 135) % 360;
                        
                        obstacleBearings.forEach(ob => {
                            const diff = Math.abs(angle - ob);
                            const dist = Math.min(diff, 360 - diff);
                            if (dist < minDistanceToObstacle) minDistanceToObstacle = dist;
                        });
                    });
                    if (minDistanceToObstacle > maxMinDistance) {
                        maxMinDistance = minDistanceToObstacle;
                        bestStartAngle = a;
                    }
                }

                const radius = 0.00018; 
                group.members.forEach((plant, i) => {
                    let angle = (bestStartAngle + (i / count) * 360) % 360;
                    if (count === 2 && i === 1) angle = (bestStartAngle + 135) % 360;
                    
                    const rad = angle * Math.PI / 180;
                    const newLat = centerLat + (radius * Math.cos(rad));
                    const newLng = centerLng + (radius * Math.sin(rad));

                    L.polyline([[centerLat, centerLng], [newLat, newLng]], {
                        color: 'white',
                        weight: 4.5,
                        opacity: 0.5,
                        pane: 'spiderPane'
                    }).addTo(groupLayers);

                    L.polyline([[centerLat, centerLng], [newLat, newLng]], {
                        color: '#ef4444',
                        weight: 2.5,
                        opacity: 0.8,
                        dashArray: '4, 4',
                        pane: 'spiderPane'
                    }).addTo(groupLayers);

                    const marker = L.marker([newLat, newLng], { 
                        icon: createPlantIcon(plant.number),
                        zIndexOffset: 1000 
                    });
                    marker.on('click', () => showPlantDetail(plant));
                    marker.addTo(groupLayers);
                    activeMarkers.push(marker);
                });
            } else {
                const plant = group.members[0];
                const marker = L.marker([plant.latitude, plant.longitude], { icon: createPlantIcon(plant.number) });
                marker.on('click', () => showPlantDetail(plant));
                marker.addTo(groupLayers);
                activeMarkers.push(marker);
            }
        });

        if (activeMarkers.length > 0) {
            const bounds = L.featureGroup(activeMarkers).getBounds();
            map.fitBounds(bounds, { padding: [50, 50] });
        }
    };

    // Modal Display Logic
    const showPlantDetail = (plant) => {
      modalContent.innerHTML = `
        <div class="w-full">
          <div class="w-full h-72 bg-forest-deep overflow-hidden relative">
            ${plant.imageUrl ? `
              <button class="w-full h-full cursor-zoom-in" onclick="window.openLightbox('${plant.imageUrl}')">
                <img src="${plant.imageUrl}" class="w-full h-full object-cover grayscale-[0.2]" />
              </button>
            ` : `
              <div class="w-full h-full flex items-center justify-center text-sage-light/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              </div>
            `}
            <div class="absolute inset-0 bg-gradient-to-t from-forest-deep via-transparent to-transparent pointer-events-none"></div>
          </div>
          
          <div class="px-8 -mt-12 relative z-10">
            <div class="bg-forest-deep/80 backdrop-blur-xl p-6 rounded-3xl border border-white/10 shadow-xl mb-8">
              <div class="text-[10px] font-black text-earth-brown uppercase tracking-[0.2em] mb-3 font-header">Species Discovery</div>
              <h2 class="text-3xl font-extrabold text-cream-warm leading-tight font-header uppercase tracking-tight">${plant.scientificName}</h2>
              <h3 class="text-lg font-medium text-cream-warm/70 italic mt-2">${plant.commonName}</h3>
            </div>

            <div class="space-y-6">
              <div class="grid grid-cols-1 gap-y-4">
                ${[
                  { label: 'Leaf Arrangement', val: plant.leafArrangement },
                  { label: 'Leaf Shape', val: plant.leafShape },
                  { label: 'Leaf Margin', val: plant.leafMargin },
                  { label: 'Bark Features', val: plant.bark },
                  { label: 'Flower', val: plant.flower },
                  { label: 'Fruit', val: plant.fruit },
                  { label: 'Family', val: plant.family }
                ].filter(f => f.val).map(f => `
                  <div class="flex items-baseline gap-6 border-b border-white/5 pb-4">
                    <div class="w-32 shrink-0 text-[10px] font-black text-earth-brown uppercase tracking-widest font-header">${f.label}</div>
                    <div class="text-[17px] text-cream-warm font-semibold leading-snug">${f.val}</div>
                  </div>
                `).join('')}
              </div>
            </div>
          </div>
        </div>
      `;
      modal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    };

    closeModal.addEventListener('click', () => {
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }
    });

    window.focusPlant = (lat, lng, id) => {
      fetch('/api/plants.json')
        .then(res => res.json())
        .then(plants => {
          const plant = plants.find(p => p.id === id);
          if (plant) {
            const btns = document.querySelectorAll('.group-filter-btn');
            btns.forEach(btn => {
                const b = btn;
                if (b.dataset.group === plant.groupId) {
                    b.click();
                }
            });
            setTimeout(() => {
                map.flyTo([lat, lng], 19, { duration: 1.5 });
                setTimeout(() => showPlantDetail(plant), 1600);
            }, 300);
          }
        });
    };

    fetch('/api/plants.json')
      .then(res => res.json())
      .then(plants => {
        const sortedByGroup = {};
        plants.forEach(p => {
          if (!sortedByGroup[p.groupId]) sortedByGroup[p.groupId] = [];
          sortedByGroup[p.groupId].push(p);
        });
        
        Object.keys(sortedByGroup).forEach(gid => {
          sortedByGroup[gid].sort((a, b) => a.scientificName.localeCompare(b.scientificName));
        });

        plants.forEach(plant => {
          if (plant.latitude && plant.longitude) {
            const groupList = sortedByGroup[plant.groupId] || [];
            const plantNumber = groupList.findIndex(p => p.id === plant.id) + 1;
            
            if (!markersByGroup[plant.groupId]) markersByGroup[plant.groupId] = [];
            markersByGroup[plant.groupId].push({ ...plant, number: plantNumber });
          }
        });

        const firstBtn = document.querySelector('.group-filter-btn');
        if (firstBtn) {
            updateMapMarkers(firstBtn.dataset.group);
        }
      });

    groupFilter.addEventListener('click', (e) => {
      const btn = (e.target).closest('button');
      if (!btn) return;

      const selectedGroup = btn.dataset.group;

      document.querySelectorAll('.group-filter-btn').forEach(b => {
        b.classList.remove('bg-forest-deep', 'border-cream-warm/30');
        b.classList.add('bg-sage-muted/40', 'border-white/10', 'text-cream-warm/60');
        b.classList.remove('text-cream-warm');
      });
      btn.classList.add('bg-forest-deep', 'border-cream-warm/30', 'text-cream-warm');
      btn.classList.remove('bg-sage-muted/40', 'border-white/10', 'text-cream-warm/60');

      if (selectedGroup) updateMapMarkers(selectedGroup);
    });
  }
</script>

<style is:global>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
