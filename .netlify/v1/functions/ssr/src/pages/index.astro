---
import Layout from '../layouts/Layout.astro';
import CampusMap from '../components/CampusMap.astro';
import { db, Groups, Plants, eq } from 'astro:db';

const groupsData = await db.select().from(Groups);
const plantsData = await db.select().from(Plants);

// Reconstruct the grouped structure for the UI
const groups = groupsData.map(group => ({
  ...group,
  plants: plantsData.filter(p => p.groupId === group.id)
}));

const numberMap: Record<string, string> = {
  '01': 'One', '02': 'Two', '03': 'Three', '04': 'Four', '05': 'Five',
  '06': 'Six', '07': 'Seven', '08': 'Eight', '09': 'Nine', '10': 'Ten'
};

const getDisplayNumber = (name: string) => {
  const parts = name.split(' ');
  if (parts.length < 2) return name;
  const num = parts[1];
  return numberMap[num] || num;
};
---

<Layout>
	<main class="min-h-screen bg-stone-50 text-stone-900 font-sans pb-12">
		<!-- Header / Toggle -->
		<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-stone-200 px-4 py-4">
			<div class="max-w-4xl mx-auto flex flex-col items-center gap-4">
				<h1 class="text-xl font-bold tracking-tight text-stone-800">Woody ID</h1>
				
				<div class="inline-flex p-1 bg-stone-100 rounded-full border border-stone-200" id="view-toggle">
					<button 
						class="px-6 py-1.5 rounded-full text-sm font-medium transition-all bg-white shadow-sm text-stone-900"
						data-view="lists"
					>
						Lists
					</button>
					<button 
						class="px-6 py-1.5 rounded-full text-sm font-medium transition-all text-stone-500 hover:text-stone-700"
						data-view="maps"
					>
						Maps
					</button>
				</div>
			</div>
		</header>

		<!-- Lists View -->
		<div id="lists-view" class="max-w-4xl mx-auto px-4 py-8 space-y-8">
			<section>
				<h2 class="text-sm font-semibold uppercase tracking-wider text-stone-400 mb-4 px-2">Plant Groups</h2>
				<div class="flex overflow-x-auto pb-6 -mx-4 px-4 gap-4 snap-x no-scrollbar">
					{groups.map((group) => (
						<button 
							class="group-widget flex-none w-64 h-40 bg-white border border-stone-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all text-left snap-start group"
							data-group-id={group.id}
						>
							<div class="flex flex-col h-full justify-between">
								<div>
									<span class="text-xs font-bold text-green-600 uppercase tracking-widest">Group</span>
									<h3 class="text-2xl font-bold mt-1 group-hover:text-green-700 transition-colors">{getDisplayNumber(group.name)}</h3>
								</div>
								<div class="text-sm text-stone-500">
									{group.plants.length} Species
								</div>
							</div>
						</button>
					))}
				</div>
			</section>

			<!-- Detail View Container (hidden by default) -->
			<div id="group-detail" class="hidden animate-in fade-in slide-in-from-bottom-4 duration-300">
				<div class="flex items-center justify-between mb-6 px-2">
					<h2 id="detail-title" class="text-2xl font-bold"></h2>
					<button id="close-detail" class="text-sm font-medium text-stone-500 hover:text-stone-900">Close</button>
				</div>
				<div id="detail-list" class="space-y-3">
					<!-- Plants will be injected here -->
				</div>
			</div>
		</div>

		<!-- Maps View -->
		<div id="maps-view" class="hidden max-w-4xl mx-auto px-4 py-8">
			<div class="mb-6">
				<h2 class="text-2xl font-bold">Campus Map</h2>
				<p class="text-stone-500 text-sm">Find plants located across the UGA campus.</p>
			</div>
			<CampusMap />
		</div>
	</main>
</Layout>

<script define:vars={{ groups }}>
	const viewToggle = document.getElementById('view-toggle');
	const listsView = document.getElementById('lists-view');
	const mapsView = document.getElementById('maps-view');
	const groupWidgets = document.querySelectorAll('.group-widget');
	const groupDetail = document.getElementById('group-detail');
	const detailTitle = document.getElementById('detail-title');
	const detailList = document.getElementById('detail-list');
	const closeDetail = document.getElementById('close-detail');

	// Toggle between Lists and Maps
	viewToggle.addEventListener('click', (e) => {
		const button = e.target.closest('button');
		if (!button) return;

		const view = button.dataset.view;
		
		// Update UI
		viewToggle.querySelectorAll('button').forEach(btn => {
			btn.classList.remove('bg-white', 'shadow-sm', 'text-stone-900');
			btn.classList.add('text-stone-500');
		});
		button.classList.add('bg-white', 'shadow-sm', 'text-stone-900');
		button.classList.remove('text-stone-500');

		if (view === 'lists') {
			listsView.classList.remove('hidden');
			mapsView.classList.add('hidden');
		} else {
			listsView.classList.add('hidden');
			mapsView.classList.remove('hidden');
		}
	});

	// Handle group selection
	groupWidgets.forEach(widget => {
		widget.addEventListener('click', () => {
			const groupId = widget.dataset.groupId;
			const group = groups.find(g => g.id === groupId);
			
			if (group) {
				// Update title
				detailTitle.textContent = group.name;
				
				// Clear and inject plants
				detailList.innerHTML = group.plants.map(plant => `
					<div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm hover:border-green-300 transition-colors">
						<div class="flex flex-col">
							<span class="text-sm font-bold text-stone-900">${plant.scientificName}</span>
							<span class="text-xs italic text-stone-500 mb-1">${plant.family || ''} ${plant.family ? '•' : ''} ${plant.commonName}</span>
							${plant.bark ? `<div class="mt-2 text-xs text-stone-600 bg-stone-50 p-2 rounded-lg border border-stone-100"><strong>Bark:</strong> ${plant.bark}</div>` : ''}
						</div>
					</div>
				`).join('');
				
				// Show detail view
				groupDetail.classList.remove('hidden');
				
				// Scroll to detail
				groupDetail.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});
	});

	// Close detail view
	closeDetail.addEventListener('click', () => {
		groupDetail.classList.add('hidden');
	});
</script>

<style>
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
